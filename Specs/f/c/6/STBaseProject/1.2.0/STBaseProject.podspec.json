{
  "name": "STBaseProject",
  "version": "1.2.0",
  "summary": "Modular iOS foundation library with MVVM base abstractions.",
  "description": "STBaseProject provides modular iOS foundation components built on MVVM base types.\nIt includes reusable UI components and shared utilities for networking, localization, image handling, and security.\nAvailable via CocoaPods subspecs and Swift Package Manager.",
  "homepage": "https://github.com/i-stack/STBaseProject",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "i-stack": "songshoubing7664@163.com"
  },
  "source": {
    "git": "https://github.com/i-stack/STBaseProject.git",
    "tag": "1.2.0"
  },
  "documentation_url": "https://github.com/i-stack/STBaseProject/blob/main/README.md",
  "readme": "https://github.com/i-stack/STBaseProject/blob/main/README.md",
  "platforms": {
    "ios": "16.0"
  },
  "swift_versions": [
    "5.0",
    "5.1",
    "5.2",
    "5.3",
    "5.4",
    "5.5",
    "5.6",
    "5.7",
    "5.8",
    "5.9",
    "5.10",
    "5.11"
  ],
  "requires_arc": true,
  "default_subspecs": [
    "STBaseProject"
  ],
  "subspecs": [
    {
      "name": "STBaseProject",
      "source_files": "Sources/**/*.swift",
      "exclude_files": [
        "Sources/STContacts/**/*.swift",
        "Sources/STLocation/**/*.swift",
        "Sources/STMedia/**/*.swift",
        "Sources/STMarkdown/**/*.swift"
      ]
    },
    {
      "name": "STContacts",
      "source_files": "Sources/STContacts/*.swift"
    },
    {
      "name": "STLocation",
      "source_files": "Sources/STLocation/*.swift"
    },
    {
      "name": "STMedia",
      "source_files": "Sources/STMedia/*.swift"
    }
  ],
  "swift_version": "5.11"
}
