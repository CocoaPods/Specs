{
  "name": "WorkstationCccSdk",
  "version": "0.0.1",
  "summary": "Workstation CCC desk capability SDK (Rust core, UniFFI Swift bindings).",
  "description": "Cross-platform Rust core for the workstation desk SDK:\nlogin + online + WS heartbeat/reconnect + agent state + minimal s2c signal dispatch.",
  "homepage": "https://cloud.tencent.com/document/product/269/96056",
  "license": "Proprietary",
  "authors": {
    "Tencent CCC Team": "owennwang@tencent.com"
  },
  "source": {
    "http": "https://www.tencentclass.net/resources/workstation/ios/0.0.1/WorkstationCccSdk-0.0.1.tar.gz"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": "5.5",
  "static_framework": true,
  "vendored_frameworks": "WorkstationCccSdk.xcframework",
  "source_files": "swift/*.swift",
  "preserve_paths": "swift/*",
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "-lc++",
    "ENABLE_BITCODE": "NO",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "swift_version": "5.5"
}
