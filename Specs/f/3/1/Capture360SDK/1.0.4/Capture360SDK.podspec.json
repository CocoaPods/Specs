{
  "name": "Capture360SDK",
  "version": "1.0.4",
  "summary": "Capture360SDK framework for 360 pano images",
  "homepage": "https://github.com/ManojAtamai/Capture360",
  "license": {
    "type": "LGPL-3.0"
  },
  "authors": {
    "Atamai": "manoj.v@atamai.in"
  },
  "source": {
    "http": "https://github.com/ManojAtamai/Capture360/releases/download/1.0.3/Insta360-1.0.3.zip"
  },
  "platforms": {
    "ios": "12.1"
  },
  "requires_arc": true,
  "static_framework": true,
  "vendored_frameworks": [
    "**/INSCameraSDK.xcframework",
    "**/INSCameraServiceSDK.xcframework",
    "**/INSCoreMedia.xcframework",
    "**/SSZipArchive.xcframework",
    "**/SnapKit.xcframework"
  ],
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64",
    "DEFINES_MODULE": "YES",
    "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) TO_B_SDK=1"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  }
}
