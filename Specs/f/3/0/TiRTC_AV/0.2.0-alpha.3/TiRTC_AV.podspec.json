{
  "name": "TiRTC_AV",
  "version": "0.2.0-alpha.3",
  "summary": "Real-time AV SDK for TiRTC Matrix Darwin clients",
  "description": "Darwin client AV SDK for TiRTC Matrix iOS and macOS applications.",
  "homepage": "https://tange.ai/",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "allenfeng": "fengjun.dev@gmail.com"
  },
  "readme": "README.md",
  "source": {
    "http": "https://icam-media-cloud-user-public.oss-cn-shenzhen.aliyuncs.com/RAPID_RELEASE/TiRTC_AV_Darwin/v0.2.0-alpha.3/TiRTC_AV.pod.zip"
  },
  "swift_versions": "6.0",
  "platforms": {
    "ios": "13.0",
    "osx": "11.5"
  },
  "vendored_frameworks": "TiRTC_AV.xcframework",
  "preserve_paths": [
    "ios-arm64/WebRTC.framework",
    "metadata/*"
  ],
  "ios": {
    "vendored_frameworks": "ios-arm64/WebRTC.framework",
    "frameworks": [
      "CFNetwork",
      "UIKit",
      "Metal",
      "MetalKit",
      "OpenGLES"
    ]
  },
  "pod_target_xcconfig": {
    "LD_RUNPATH_SEARCH_PATHS": "$(inherited) @executable_path/Frameworks @loader_path/Frameworks",
    "ARCHS": "arm64",
    "ONLY_ACTIVE_ARCH": "YES"
  },
  "user_target_xcconfig": {
    "ARCHS": "arm64",
    "ONLY_ACTIVE_ARCH": "YES"
  },
  "libraries": [
    "c++",
    "z"
  ],
  "frameworks": [
    "AVFoundation",
    "AudioToolbox",
    "CoreAudio",
    "CoreGraphics",
    "CoreMedia",
    "CoreVideo",
    "Foundation",
    "QuartzCore",
    "Security",
    "SystemConfiguration",
    "VideoToolbox"
  ],
  "osx": {
    "frameworks": [
      "AppKit"
    ]
  },
  "swift_version": "6.0"
}
