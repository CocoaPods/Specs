{
  "name": "CDYelpFusionKit",
  "version": "5.1.0",
  "cocoapods_version": ">= 1.13.0",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "summary": "An extensive Swift wrapper for the Yelp Fusion API.",
  "description": "This Swift wrapper covers all possible network endpoints and responses for the Yelp Fusion API.",
  "homepage": "https://github.com/chrisdhaan/CDYelpFusionKit",
  "authors": {
    "Christopher de Haan": "contact@christopherdehaan.me"
  },
  "source": {
    "git": "https://github.com/chrisdhaan/CDYelpFusionKit.git",
    "tag": "5.1.0"
  },
  "documentation_url": "https://chrisdhaan.github.io/CDYelpFusionKit/",
  "platforms": {
    "ios": "12.0",
    "osx": "11.0",
    "tvos": "12.0",
    "watchos": "4.0",
    "visionos": "1.0"
  },
  "swift_versions": [
    "5"
  ],
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Core",
      "source_files": "Source/**/*.swift",
      "exclude_files": "Source/Testing/**/*.swift",
      "resource_bundles": {
        "CDYelpFusionKit": [
          "Source/PrivacyInfo.xcprivacy"
        ]
      },
      "resources": [
        "Resources/*.xcassets"
      ],
      "dependencies": {
        "Alamofire": [
          "~> 5.9"
        ]
      }
    },
    {
      "name": "Testing",
      "source_files": "Source/Testing/**/*.swift",
      "dependencies": {
        "CDYelpFusionKit/Core": [

        ]
      }
    }
  ],
  "swift_version": "5"
}
