{
  "name": "AFNetworking_CHO",
  "version": "4.0.2",
  "license": "MIT",
  "summary": "Custom networking framework for Apple platforms.",
  "homepage": "https://github.com/Choco1ate/AFNetworking_CHO",
  "authors": {
    "chocolate": "12@qq.com"
  },
  "source": {
    "git": "https://github.com/Choco1ate/AFNetworking_CHO.git",
    "tag": "4.0.2"
  },
  "requires_arc": true,
  "platforms": {
    "ios": "9.0",
    "osx": "10.12"
  },
  "source_files": "AFNetworking/**/*.{h,m}",
  "ios": {
    "pod_target_xcconfig": {
      "PRODUCT_BUNDLE_IDENTIFIER": "com.alamofire.AFNetworking"
    }
  },
  "osx": {
    "pod_target_xcconfig": {
      "PRODUCT_BUNDLE_IDENTIFIER": "com.alamofire.AFNetworking"
    }
  },
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES"
  }
}
