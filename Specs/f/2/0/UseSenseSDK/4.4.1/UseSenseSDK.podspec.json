{
  "name": "UseSenseSDK",
  "version": "4.4.1",
  "summary": "Human presence verification SDK for iOS.",
  "description": "Native iOS SDK for human presence verification. Verify real humans,\ndetect deepfakes, and prevent identity fraud with three independent\nverification pillars: DeepSense, LiveSense, and MatchSense.\nIncludes on-device 3D liveness (Geometric Coherence), client-side\npresentation attack detection (Suspicion Engine), and inline step-up\nchallenges (Flash Reflection, RMAS).",
  "homepage": "https://github.com/qudusadeyemi/usesense-ios-sdk",
  "license": {
    "type": "Proprietary",
    "file": "LICENSE"
  },
  "authors": {
    "UseSense": "support@usesense.ai"
  },
  "source": {
    "git": "https://github.com/qudusadeyemi/usesense-ios-sdk.git",
    "tag": "v4.4.1"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.9",
  "source_files": "Sources/UseSense/**/*.swift",
  "resource_bundles": {
    "UseSenseSDK": [
      "Sources/UseSense/Resources/**/*.xcprivacy",
      "Sources/UseSense/Resources/**/*.mlmodel",
      "Sources/UseSense/Resources/**/*.json",
      "Sources/UseSense/Resources/**/*.task",
      "Sources/UseSense/Resources/**/*.lproj"
    ]
  },
  "frameworks": [
    "AVFoundation",
    "CoreMotion",
    "UIKit",
    "Accelerate"
  ],
  "weak_frameworks": [
    "LocalAuthentication",
    "DeviceCheck",
    "CryptoKit"
  ],
  "dependencies": {
    "UseSenseMediaPipe": [
      "4.4.1"
    ]
  },
  "exclude_files": [
    "Tests/**/*",
    "Example/**/*",
    "UseSenseDemo/**/*"
  ],
  "pod_target_xcconfig": {
    "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "$(inherited)",
    "APPLICATION_EXTENSION_API_ONLY": "NO"
  },
  "static_framework": true,
  "swift_version": "5.9"
}
