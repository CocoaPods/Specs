{
  "name": "NewGRDB.swift",
  "version": "7.10.0",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "summary": "A toolkit for SQLite databases, with a focus on application development.",
  "homepage": "https://github.com/taojeff/NewRGDB.swift.git",
  "authors": {
    "Gwendal Roué": "gr@pierlis.com"
  },
  "source": {
    "git": "https://github.com/taojeff/NewRGDB.swift.git",
    "tag": "v7.10.0"
  },
  "module_name": "GRDB",
  "swift_versions": [
    "5.9",
    "6.0",
    "6.1"
  ],
  "platforms": {
    "ios": "13.0"
  },
  "default_subspecs": "standard",
  "subspecs": [
    {
      "name": "standard",
      "source_files": [
        "GRDB/**/*.swift",
        "Support/grdb_config.h"
      ],
      "frameworks": "Foundation",
      "libraries": "sqlite3",
      "xcconfig": {
        "OTHER_SWIFT_FLAGS": "$(inherited) -D SQLITE_ENABLE_FTS5 -D GRDBFRAMEWORK"
      }
    },
    {
      "name": "SQLCipher",
      "source_files": [
        "GRDB/**/*.swift",
        "Support/SQLCipher_config.h"
      ],
      "frameworks": "Foundation",
      "dependencies": {
        "SQLCipher": [
          ">= 3.4.2"
        ]
      },
      "xcconfig": {
        "OTHER_SWIFT_FLAGS": "$(inherited) -D SQLITE_HAS_CODEC -D GRDBCIPHER -D SQLITE_ENABLE_FTS5",
        "OTHER_CFLAGS": "$(inherited) -DSQLITE_HAS_CODEC -DGRDBCIPHER -DSQLITE_ENABLE_FTS5",
        "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) SQLITE_HAS_CODEC=1 GRDBCIPHER=1 SQLITE_ENABLE_FTS5=1"
      }
    }
  ],
  "swift_version": "6.1"
}
