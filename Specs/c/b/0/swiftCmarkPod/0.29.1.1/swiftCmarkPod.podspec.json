{
  "name": "swiftCmarkPod",
  "version": "0.29.1.1",
  "summary": "A CocoaPods wrapper for the cmark-gfm library.",
  "description": "This pod provides the cmark-gfm library, including both the core parser and GFM extensions, for use in iOS, macOS, and other Apple platforms.",
  "homepage": "https://github.com/taojeff/swiftCmarkPod",
  "license": {
    "type": "BSD-2-Clause",
    "file": "COPYING"
  },
  "authors": {
    "GIKICoder": "https://github.com/GIKICoder"
  },
  "source": {
    "git": "https://github.com/taojeff/swiftCmarkPod.git",
    "tag": "0.29.1.1"
  },
  "platforms": {
    "ios": "12.0"
  },
  "module_name": "cmark_gfm",
  "source_files": [
    "src/**/*.{h,c,inc}",
    "extensions/**/*.{h,c,inc}"
  ],
  "preserve_paths": [
    "src/**/*",
    "extensions/**/*"
  ],
  "public_header_files": [
    "src/include/*.h",
    "extensions/include/*.h"
  ],
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": "$(PODS_TARGET_SRCROOT)/src/include $(PODS_TARGET_SRCROOT)/src $(PODS_TARGET_SRCROOT)/extensions/include",
    "GCC_PREPROCESSOR_DEFINITIONS": "CMARK_GFM=1 CMARK_GFM_STATIC_DEFINE=1"
  }
}
