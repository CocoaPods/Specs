{
  "name": "TraceletSDK",
  "version": "1.0.8",
  "summary": "Production-grade background geolocation SDK for iOS.",
  "description": "TraceletSDK provides battery-conscious background geolocation with motion detection,\ngeofencing, SQLite persistence, HTTP sync, and headless execution for iOS.\nFramework-agnostic — usable from Flutter, React Native, Capacitor, or native iOS apps.",
  "homepage": "https://github.com/Ikolvi/Tracelet/tree/main/sdk/ios",
  "license": {
    "type": "Apache-2.0",
    "file": "LICENSE"
  },
  "authors": {
    "Ikolvi": "contact@ikolvi.com"
  },
  "source": {
    "git": "https://github.com/Ikolvi/Tracelet.git",
    "tag": "sdk-ios-v1.0.8"
  },
  "platforms": {
    "ios": "14.0"
  },
  "swift_versions": "5.9",
  "source_files": "sdk/ios/Sources/TraceletSDK/**/*.swift",
  "frameworks": [
    "CoreLocation",
    "CoreMotion",
    "UIKit",
    "BackgroundTasks",
    "AVFoundation",
    "AudioToolbox",
    "Network",
    "DeviceCheck"
  ],
  "libraries": "sqlite3",
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "swift_version": "5.9"
}
