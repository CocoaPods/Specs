{
  "name": "TopOnUBiXMAdapter",
  "version": "6.4.93.3",
  "summary": "TopOn UBiX聚合广告变现SDK Adapter",
  "homepage": "https://www.ubixai.com/product/md",
  "authors": {
    "zhugq": "guoqiang.zhu@ubixai.com"
  },
  "source": {
    "git": "https://gitee.com/ubixai/mdnow-ios-adapter-topon.git",
    "tag": "6.4.93.3"
  },
  "platforms": {
    "ios": "12.0"
  },
  "static_framework": true,
  "ios": {
    "source_files": "TopOnUBiXMAdapter/**/*.{h,m}",
    "public_header_files": "TopOnUBiXMAdapter/**/*.h"
  },
  "xcconfig": {
    "FRAMEWORK_SEARCH_PATHS": "$(inherited) $(PODS_ROOT)/**",
    "HEADER_SEARCH_PATHS": "$(inherited) $(PODS_ROOT)/**",
    "USER_HEADER_SEARCH_PATHS": "$(inherited) $(PODS_ROOT)/**"
  },
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64",
    "OTHER_LDFLAGS": "$(inherited) -ObjC",
    "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES",
    "IPHONEOS_DEPLOYMENT_TARGET": "12.0"
  },
  "dependencies": {
    "AnyThinkiOS": [
      "6.4.93"
    ],
    "UBiXMediationSDK": [
      "2.13.0"
    ],
    "UBiXMUBiXAdapter": [
      "~> 2.10.2.0"
    ]
  }
}
