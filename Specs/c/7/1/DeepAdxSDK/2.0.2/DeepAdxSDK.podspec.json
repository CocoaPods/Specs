{
  "name": "DeepAdxSDK",
  "version": "2.0.2",
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": [
    "5.0",
    "5.1",
    "5.2",
    "5.3",
    "5.4",
    "5.5",
    "5.6",
    "5.7",
    "5.8",
    "5.9"
  ],
  "requires_arc": true,
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "summary": "DeepAdxSDK for iOS",
  "description": "欢迎大家使用DeepAdxSDK, 提供成熟聚合方案。\n为开发者提供便利，快速集成。",
  "homepage": "https://deepadx.com",
  "authors": {
    "deepadx": "ads@deepadx.com"
  },
  "source": {
    "git": "https://gitee.com/deepadx/deepadx-ios-sdk.git",
    "tag": "2.0.2"
  },
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": [
      "-ObjC"
    ],
    "ENABLE_BITCODE": "NO"
  },
  "pod_target_xcconfig": {
    "ENABLE_BITCODE": "NO"
  },
  "info_plist": {
    "GADApplicationIdentifier": "ca-app-pub-3940256099942544~1458002511"
  },
  "default_subspecs": "Core",
  "xcconfig": {
    "VALID_ARCHS": "armv7 armv7s x86_64 arm64"
  },
  "subspecs": [
    {
      "name": "Core",
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Core/DeepAdxCore.xcframework",
        "DeepAdxSDK/Frameworks/Adspot/DeepAdxAdspot.xcframework"
      ],
      "frameworks": [
        "CoreLocation",
        "SystemConfiguration",
        "CoreGraphics",
        "CoreMotion",
        "CoreTelephony",
        "AdSupport",
        "QuartzCore",
        "WebKit",
        "MessageUI",
        "SafariServices",
        "AVFoundation",
        "EventKit",
        "CoreMedia",
        "StoreKit"
      ],
      "libraries": "c++",
      "weak_frameworks": "WebKit"
    },
    {
      "name": "CSJ",
      "dependencies": {
        "DeepAdxSDK/Core": [

        ],
        "Ads-CN": [
          "6.7.0.8"
        ]
      },
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Adapter/DeepAdxAdapter_CSJ.xcframework"
      ]
    },
    {
      "name": "GDT",
      "dependencies": {
        "DeepAdxSDK/Core": [

        ],
        "GDTMobSDK": [
          "4.15.80"
        ]
      },
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Adapter/DeepAdxAdapter_GDT.xcframework"
      ]
    },
    {
      "name": "KS",
      "dependencies": {
        "DeepAdxSDK/Core": [

        ],
        "KSAdSDK": [
          "4.12.20.3"
        ]
      },
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Adapter/DeepAdxAdapter_KS.xcframework"
      ]
    },
    {
      "name": "BD",
      "dependencies": {
        "DeepAdxSDK/Core": [

        ],
        "BaiduMobAdSDK": [
          "10.032"
        ]
      },
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Adapter/DeepAdxAdapter_BD.xcframework"
      ]
    },
    {
      "name": "GG",
      "dependencies": {
        "DeepAdxSDK/Core": [

        ],
        "Google-Mobile-Ads-SDK": [
          "12.8.0"
        ]
      },
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Adapter/DeepAdxAdapter_GG.xcframework"
      ],
      "resources": "DeepAdxSDK/Resources/GGResource.bundle"
    },
    {
      "name": "PAG",
      "dependencies": {
        "DeepAdxSDK/Core": [

        ],
        "Ads-Global/PangleSDK": [
          "7.9.0.6"
        ]
      },
      "vendored_frameworks": [
        "DeepAdxSDK/Frameworks/Adapter/DeepAdxAdapter_PAG.xcframework"
      ]
    }
  ],
  "swift_version": "5.9"
}
