{
  "name": "MAXMediationAdMaster",
  "version": "2.0.1.0",
  "summary": "AppLovin MAX Mediation Adapter for AdMaster SDK",
  "description": "AppLovin MAX Mediation Adapter for AdMaster SDK. Enables AdMaster ads through MAX custom SDK networks\n(app open, banner / leader / mrec, interstitial, rewarded, native). In MAX dashboard create a Custom Network (SDK type)\nand set iOS Adapter Class Name to ALAdMasterMediationAdapter.",
  "homepage": "https://github.com/AdMasterDev/AdMasterSDK-iOS",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "AdMasterDev": "dev0.admaster@gmail.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/AdMasterDev/AdMasterSDK-iOS.git",
    "tag": "2.0.1.0"
  },
  "source_files": "Mediation/MAX/*.{h,m}",
  "public_header_files": "Mediation/MAX/ALAdMasterMediationAdapter.h",
  "static_framework": true,
  "dependencies": {
    "AppLovinSDK": [
      ">= 13.0.0"
    ],
    "AdMasterSDK": [
      ">= 2.0.1"
    ]
  },
  "frameworks": [
    "AdSupport",
    "AVFoundation",
    "CoreGraphics",
    "CoreLocation",
    "CoreMotion",
    "CoreTelephony",
    "QuartzCore",
    "SystemConfiguration",
    "SafariServices",
    "StoreKit",
    "WebKit"
  ],
  "libraries": "c++",
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "swift_version": "5.0"
}
