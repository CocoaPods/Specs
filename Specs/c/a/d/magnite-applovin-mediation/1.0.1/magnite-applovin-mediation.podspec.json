{
  "name": "magnite-applovin-mediation",
  "version": "1.0.1",
  "summary": "Magnite <-> AppLovin MAX iOS Mediation Adapter.",
  "description": "Using this adapter you will be able to integrate Magnite SDK via AppLovin MAX mediation",
  "homepage": "https://www.magnite.com/",
  "license": {
    "type": "Commercial",
    "file": "LICENSE.md"
  },
  "authors": {
    "Magnite": "sdk@magnite.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "source": {
    "git": "https://github.com/MagniteEngineering/ios-applovinmax-mediation.git",
    "tag": "1.0.1"
  },
  "source_files": "MagniteApplovinMediation/*.{h,m}",
  "frameworks": [
    "Foundation",
    "UIKit"
  ],
  "requires_arc": true,
  "static_framework": true,
  "user_target_xcconfig": {
    "ONLY_ACTIVE_ARCH": "YES"
  },
  "dependencies": {
    "AppLovinSDK": [
      ">= 12",
      "< 14"
    ],
    "MagniteSDK": [
      "~> 1.0"
    ]
  }
}
