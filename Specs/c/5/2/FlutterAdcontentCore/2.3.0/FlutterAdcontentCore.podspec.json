{
  "name": "FlutterAdcontentCore",
  "version": "2.3.0",
  "summary": "A Flutter Adcontent plugin core library for iOS.",
  "description": "A Flutter Adcontent plugin core library for iOS.",
  "homepage": "https://flutterads.top/",
  "license": {
    "type": "Apache-2.0",
    "file": "LICENSE"
  },
  "authors": {
    "FlutterAds": "https://flutterads.top/"
  },
  "source": {
    "git": "https://github.com/FlutterAds/flutteradc-core-ios.git",
    "tag": "v2.3.0"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "static_framework": true,
  "vendored_frameworks": "FlutterAdcontentCore.xcframework",
  "dependencies": {
    "FlutterAdsCore": [
      "2.2.0"
    ]
  },
  "frameworks": "Foundation",
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386",
    "VALID_ARCHS": "arm64 arm64e x86_64",
    "OTHER_LDFLAGS": "-ObjC",
    "HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/Headers/Public/FlutterAdcontentCore\"",
    "PUBLIC_HEADERS_FOLDER_PATH": "${PRODUCT_NAME}.framework/Headers"
  }
}
