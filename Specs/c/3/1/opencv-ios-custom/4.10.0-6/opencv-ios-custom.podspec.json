{
  "name": "opencv-ios-custom",
  "version": "4.10.0-6",
  "summary": "OpenCV 4.10.0 for iOS — SIFT and full stitching pipeline, device + simulator",
  "homepage": "https://github.com/jfreyer/opencv-ios-custom",
  "license": {
    "type": "Apache 2.0"
  },
  "authors": {
    "jfreyer": "j.freyer@forstify.de"
  },
  "source": {
    "http": "https://github.com/jfreyer/opencv-ios-custom/releases/download/4.10.0-6/opencv2.xcframework.zip",
    "sha256": "f56868976edcd270e1149171aa179103c18eb77fa798c5b5002ae9ae3e054cb9"
  },
  "platforms": {
    "ios": "13.0"
  },
  "requires_arc": false,
  "vendored_frameworks": "opencv2.xcframework",
  "ios": {
    "frameworks": [
      "AssetsLibrary",
      "AVFoundation",
      "CoreGraphics",
      "CoreMedia",
      "CoreVideo",
      "Foundation",
      "QuartzCore",
      "UIKit"
    ]
