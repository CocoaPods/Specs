{
  "name": "FZZipArchive",
  "version": "1.0.0",
  "summary": "基于SSZipArchive-2.4.3版本, 添加2个方法",
  "description": "基于SSZipArchive-2.4.3版本, 添加读取zip包内目录结构和读取zip包内文件的方法",
  "homepage": "https://github.com/FitchZhuang/FZZipArchive",
  "license": {
    "type": "MIT",
    "file": "LICENSE.txt"
  },
  "authors": {
    "FitchZhuang": "fitchzhuang@163.com"
  },
  "source": {
    "git": "https://github.com/FitchZhuang/FZZipArchive.git",
    "tag": "1.0.0"
  },
  "platforms": {
    "ios": "9.0",
    "tvos": "9.0",
    "osx": "10.9",
    "watchos": "2.0"
  },
  "source_files": [
    "SSZipArchive/*.{m,h}",
    "SSZipArchive/include/*.{m,h}",
    "SSZipArchive/minizip/*.{c,h}"
  ],
  "public_header_files": "SSZipArchive/*.h",
  "libraries": [
    "z",
    "iconv"
  ],
  "frameworks": "Security",
  "static_framework": true,
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "GCC_PREPROCESSOR_DEFINITIONS": "HAVE_INTTYPES_H HAVE_PKCRYPT HAVE_STDINT_H HAVE_WZAES HAVE_ZLIB"
  }
}
