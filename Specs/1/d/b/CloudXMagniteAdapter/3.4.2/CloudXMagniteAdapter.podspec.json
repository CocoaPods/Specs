{
  "name": "CloudXMagniteAdapter",
  "version": "3.4.2",
  "summary": "CloudX Magnite Adapter - Static Framework",
  "description": "Magnite adapter for CloudX iOS SDK - binary distribution. Supports Banner, Interstitial, and Rewarded formats via MagniteSDK (waterfall-only).",
  "homepage": "https://github.com/cloudx-io/cloudx-ios",
  "license": {
    "type": "Business Source License 1.1"
  },
  "authors": {
    "CloudX": "support@cloudx.io"
  },
  "source": {
    "git": "https://github.com/cloudx-io/cloudx-ios.git",
    "tag": "v3.4.2"
  },
  "platforms": {
    "ios": "13.0"
  },
  "vendored_frameworks": "adapter-magnite/CloudXMagniteAdapter.xcframework",
  "dependencies": {
    "CloudXCore": [
      "3.4.2"
    ],
    "MagniteSDK": [
      "~> 1.0.0"
    ]
  },
  "frameworks": [
    "AVFoundation",
    "AdSupport",
    "CoreGraphics",
    "CoreMedia",
    "CoreTelephony",
    "Foundation",
    "JavaScriptCore",
    "QuartzCore",
    "StoreKit",
    "SystemConfiguration",
    "UIKit",
    "WebKit"
  ],
  "weak_frameworks": [
    "AppTrackingTransparency"
  ],
  "requires_arc": true,
  "static_framework": true,
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "swift_versions": [
    "5.0",
    "5.1",
    "5.2",
    "5.3",
    "5.4",
    "5.5",
    "5.6",
    "5.7",
    "5.8",
    "5.9",
    "6.0",
    "6.1",
    "6.2"
  ],
  "swift_version": "6.2"
}
