{
  "name": "BlueBillywigNativePlayerKit-iOS",
  "version": "8.51.0",
  "summary": "iOS SDK for playing Blue Billywig video content with native playback",
  "description": "The Blue Billywig Native Player Kit is an iOS SDK for playing video content from\nthe Blue Billywig Online Video Platform. It provides native AVFoundation-based\nplayback with support for IMA advertising, Chromecast, Picture-in-Picture, AirPlay,\nvertical video (Shorts), and a full playback control API with event-driven delegates.",
  "homepage": "https://www.bluebillywig.com/",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Blue Billywig": "tech@bluebillywig.com"
  },
  "platforms": {
    "ios": "14.0"
  },
  "ios": {
    "vendored_frameworks": "BBNativePlayerKit.xcframework"
  },
  "source": {
    "git": "https://github.com/bluebillywig/bbnativeplayerkit-cocoapod.git",
    "tag": "8.51.0"
  },
  "dependencies": {
    "GoogleAds-IMA-iOS-SDK": [
      "3.23.0"
    ],
    "BlueBillywigNativeShared-iOS": [
      "8.51.0"
    ],
    "GoogleUserMessagingPlatform": [
      "~> 2.1"
    ]
  },
  "frameworks": [
    "UIKit",
    "Foundation",
    "AVFoundation"
  ],
  "default_subspecs": "none",
  "subspecs": [
    {
      "name": "GoogleCastSDK",
      "dependencies": {
        "google-cast-sdk-dynamic-xcframework-ios-bb": [
          "4.8.0"
        ]
      }
    },
    {
      "name": "GoogleCastSDKNoBluetooth",
      "dependencies": {
        "google-cast-sdk-dynamic-xcframework-ios-no-bluetooth-bb": [
          "4.8.0"
        ]
      }
    }
  ]
}
