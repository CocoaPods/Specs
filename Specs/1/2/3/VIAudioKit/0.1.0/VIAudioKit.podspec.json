{
  "name": "VIAudioKit",
  "version": "0.1.0",
  "summary": "Cross-platform audio player with chunked downloading, custom decoding and AVAudioEngine rendering.",
  "homepage": "https://github.com/wanqingrongruo/VIAudioKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "VIAudioKit": "wanqingrongruo"
  },
  "source": {
    "git": "https://github.com/wanqingrongruo/VIAudioKit.git",
    "tag": "0.1.0"
  },
  "platforms": {
    "ios": "15.0",
    "osx": "12.0"
  },
  "swift_versions": "5.9",
  "static_framework": true,
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Core",
      "source_files": [
        "Sources/VIAudioDownloader/**/*.swift",
        "Sources/VIAudioDecoder/**/*.swift",
        "Sources/VIAudioPlayer/**/*.swift"
      ],
      "frameworks": [
        "Foundation",
        "AVFoundation",
        "AudioToolbox",
        "Network",
        "CryptoKit"
      ],
      "pod_target_xcconfig": {
        "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "COCOAPODS"
      }
    }
  ],
  "swift_version": "5.9"
}
