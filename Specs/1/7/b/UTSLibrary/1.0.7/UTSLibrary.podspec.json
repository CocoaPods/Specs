{
  "name": "UTSLibrary",
  "version": "1.0.7",
  "summary": "A Swift library for sing-box VPN integration with Objective-C support.",
  "homepage": "https://gitee.com/tyousan_admin/UTSLibrary",
  "license": {
    "type": "MIT",
    "file": "License.md"
  },
  "authors": {
    "176142998": "176142998@qq.com"
  },
  "source": {
    "git": "https://gitee.com/tyousan_admin/UTSLibrary.git",
    "tag": "1.0.7"
  },
  "swift_versions": "5.0",
  "platforms": {
    "ios": "15.0"
  },
  "source_files": "Sources/Library/**/*.{swift,h}",
  "public_header_files": "Sources/Library/ObjCWrapper/**/*.h",
  "module_name": "UTSLibrary",
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "SWIFT_COMPILATION_MODE": "wholemodule"
  },
  "dependencies": {
    "UTSLibbox": [
      "~> 1.0.2"
    ],
    "GRDB.swift": [
      "~> 6.24.1"
    ],
    "UTSBinaryCodable": [
      "~> 3.0.3"
    ]
  },
  "static_framework": true,
  "frameworks": [
    "Foundation",
    "Combine",
    "Network",
    "NetworkExtension"
  ],
  "weak_frameworks": "SystemExtensions",
  "swift_version": "5.0"
}
