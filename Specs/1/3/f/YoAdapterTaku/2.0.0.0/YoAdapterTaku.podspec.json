{
  "name": "YoAdapterTaku",
  "version": "2.0.0.0",
  "summary": "YoAdapterToTaku 是一个纵量广告 iOS 平台的广告聚合 SDK",
  "description": "YoAdapterTaku 是纵量广告针对 Taku 的自定义广告的适配器。",
