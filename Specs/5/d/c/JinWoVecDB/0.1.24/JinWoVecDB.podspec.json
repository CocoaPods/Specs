{
  "name": "JinWoVecDB",
  "version": "0.1.24",
  "summary": "JinWo VecDB - Fast embedding vector database for iOS",
  "description": "JinWo VecDB is a high-performance vector database supporting efficient\nembedding storage and fast KNN search on mobile devices.",
  "homepage": "https://github.com/pkjinwo/jinwo_vector_db",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "pkjinwo": "pkjinwo@users.noreply.github.com"
  },
  "source": {
    "git": "https://github.com/pkjinwo/jinwo_vector_db.git",
    "tag": "v0.1.24"
  },
  "platforms": {
    "ios": "13.0"
  },
  "static_framework": true,
  "source_files": [
    "bindings/ios/Sources/**/*.swift",
    "src/*.c",
    "include/*.h"
  ],
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "$(PODS_TARGET_SRCROOT)/include",
    "SWIFT_INCLUDE_PATHS": "$(PODS_TARGET_SRCROOT)/include",
    "OTHER_CFLAGS": "-std=c11 -O2"
  },
  "swift_versions": "5.0",
  "swift_version": "5.0"
}
