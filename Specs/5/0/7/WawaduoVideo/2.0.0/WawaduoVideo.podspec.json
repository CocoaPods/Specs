{
  "name": "WawaduoVideo",
  "version": "2.0.0",
  "summary": "适配HDEV，修复rtc静音变成听筒的问题",
  "description": "娃娃多的视频播放视图，包括对视频的音频控制、旋转、暂停等，统一管理Smart和RTC。仅支持真机（SmartPlayer 为真机静态库）。",
  "homepage": "https://gitee.com/librarybyself/wawaduo-video",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Wawaduo": "1739276634@qq.com"
  },
  "source": {
    "git": "https://gitee.com/librarybyself/wawaduo-video.git",
    "tag": "2.0.0"
  },
  "platforms": {
    "ios": "16.0"
  },
  "swift_versions": "5.0",
  "static_framework": true,
  "frameworks": [
    "UIKit",
    "AVFoundation",
    "AVFAudio",
    "AudioToolbox",
    "CoreAudio",
    "CoreGraphics",
    "CoreMedia",
    "CoreVideo",
    "GLKit",
    "VideoToolbox",
    "Network",
    "Security"
  ],
  "libraries": [
    "c++",
    "resolv"
  ],
  "source_files": "WawaduoVideo/Classes/**/*.{swift,h,m}",
  "exclude_files": "WawaduoVideo/Classes/WebRTC.xcframework/**/*",
  "vendored_frameworks": "WawaduoVideo/Classes/WebRTC.xcframework",
  "resource_bundles": {
    "WawaduoVideo": [
      "WawaduoVideo/Assets/*"
    ]
  },
  "pod_target_xcconfig": {
    "SUPPORTED_PLATFORMS": "iphoneos"
  },
  "user_target_xcconfig": {
    "SUPPORTED_PLATFORMS": "iphoneos"
  },
  "dependencies": {
    "SnapKit": [
      "~> 5.7.1"
    ],
    "SmartPlayer": [
      "0.0.4"
    ]
  },
  "swift_version": "5.0"
}
