{
  "name": "MSHLiveStream",
  "version": "1.3.18",
  "module_name": "MSHLiveStream",
  "summary": "A consolidated high-level wrapper around HaishinKit.",
  "description": "MSHLiveStream is a consolidated SDK that includes HaishinKit, RTMP, SRT, RTC and MoQT features. Note: iOS Simulator on Intel Macs (x86_64) is not supported due to upstream dependency limitations.",
  "homepage": "https://stv-git.sohatv.vn/hungnt/mshlivestream-ios-public",
  "license": {
    "type": "MIT",
    "file": "LICENSE.md"
  },
  "authors": {
    "hungnt": "zelly0kun1@gmail.com"
  },
  "source": {
    "git": "https://stv-git.sohatv.vn/hungnt/mshlivestream-ios-public.git",
    "tag": "1.3.18"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.10",
  "vendored_frameworks": [
    "MSHLiveStream.xcframework",
    "HaishinKit.xcframework",
    "Logboard.xcframework",
    "RTMPHaishinKit.xcframework"
  ],
  "dependencies": {
    "libsrt": [
      "1.5.8"
    ],
    "libdatachannel": [
      "0.24.4"
    ]
  },
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64"
  },
  "user_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64"
  },
  "swift_version": "5.10"
}
