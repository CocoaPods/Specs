{
  "name": "MSHLiveStream",
  "version": "1.3.2",
  "module_name": "MSHLiveStream",
  "summary": "A consolidated high-level wrapper around HaishinKit.",
  "description": "MSHLiveStream is a consolidated SDK that includes HaishinKit, RTMP, SRT, RTC and MoQT features in a single XCFramework.",
  "homepage": "https://stv-git.sohatv.vn/hungnt/mshlivestream-ios-public",
  "license": {
    "type": "MIT",
    "file": "LICENSE.md"
  },
  "authors": {
    "hungnt": "zelly0kun1@gmail.com"
  },
  "source": {
    "git": "https://stv-git.sohatv.vn/hungnt/mshlivestream-ios-public.git",
    "tag": "1.3.2"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.10",
  "vendored_frameworks": [
    "MSHLiveStream.xcframework",
    "libsrt.xcframework",
    "libdatachannel.xcframework"
  ],
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "$(inherited) \"${PODS_ROOT}/MSHLiveStream/libsrt.xcframework/ios-arm64/Headers/libsrt\" \"${PODS_ROOT}/MSHLiveStream/libdatachannel.xcframework/ios-arm64/Headers/libdatachannel\" \"${PODS_ROOT}/MSHLiveStream/libsrt.xcframework/ios-arm64_x86_64-simulator/Headers/libsrt\" \"${PODS_ROOT}/MSHLiveStream/libdatachannel.xcframework/ios-arm64_x86_64-simulator/Headers/libdatachannel\"",
    "SWIFT_INCLUDE_PATHS": "$(inherited) \"${PODS_ROOT}/MSHLiveStream/libsrt.xcframework/ios-arm64/Headers/libsrt\" \"${PODS_ROOT}/MSHLiveStream/libdatachannel.xcframework/ios-arm64/Headers/libdatachannel\" \"${PODS_ROOT}/MSHLiveStream/libsrt.xcframework/ios-arm64_x86_64-simulator/Headers/libsrt\" \"${PODS_ROOT}/MSHLiveStream/libdatachannel.xcframework/ios-arm64_x86_64-simulator/Headers/libdatachannel\"",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64"
  },
  "swift_version": "5.10"
}
