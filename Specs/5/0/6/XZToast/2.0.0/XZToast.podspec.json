{
  "name": "XZToast",
  "version": "2.0.0",
  "summary": "一种提示型消息展示组件",
  "description": "按列队显示，支持上中下显示位置，支持自定义视图，支持进度的提示型消息展示组件。",
  "homepage": "https://github.com/Xezun/XZKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Xezun": "xezun@icloud.com"
  },
  "source": {
    "git": "https://github.com/Xezun/XZKit.git",
    "tag": "2.0.0"
  },
  "readme": "https://github.com/Xezun/XZKit/blob/main/Docs/XZToast/README.md?raw=true",
  "swift_versions": "5.9",
  "platforms": {
    "ios": "13.0"
  },
  "pod_target_xcconfig": {
    "GCC_PREPROCESSOR_DEFINITIONS": "XZ_FRAMEWORK=1"
  },
  "public_header_files": [
    "Sources/ObjC/Code/XZToast/*.h",
    "Sources/ObjC/Code/XZLog/*.h",
    "Sources/ObjC/Code/XZGeometry/*.h",
    "Sources/ObjC/Code/XZExtensions/UIApplication/*.h",
    "Sources/ObjC/Code/XZExtensions/UIView/*.h",
    "Sources/ObjC/Code/XZExtensions/XZShapeView/*.h"
  ],
  "project_header_files": "Sources/ObjC/Code/XZToast/**/Private/**/*.h",
  "source_files": [
    "Sources/ObjC/Code/XZToast/**/*.{h,m}",
    "Sources/ObjC/Code/XZLog/**/*.{h,m}",
    "Sources/ObjC/Code/XZGeometry/**/*.{h,m}",
    "Sources/ObjC/Code/XZExtensions/UIApplication/**/*.{h,m}",
    "Sources/ObjC/Code/XZExtensions/UIView/**/*.{h,m}",
    "Sources/ObjC/Code/XZExtensions/XZShapeView/**/*.{h,m}"
  ],
  "swift_version": "5.9"
}
