{
  "name": "ToBidUBiXMAdapter",
  "version": "5.5.6.1",
  "summary": "ToBid UBiX聚合广告变现SDK Adapter",
  "homepage": "https://www.ubixai.com/product/md",
  "authors": {
    "zhugq": "guoqiang.zhu@ubixai.com"
  },
  "source": {
    "git": "https://gitee.com/ubixai/mdnow-ios-adapter-tobid.git",
    "tag": "5.5.6.1"
  },
  "platforms": {
    "ios": "11.0"
  },
  "static_framework": true,
  "ios": {
    "source_files": "WindMillUBiXMAdapter/**/*.{h,m}",
    "public_header_files": "WindMillUBiXMAdapter/**/*.h"
  },
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64",
    "OTHER_LINK_FLAG": "$(inherited) -ObjC",
    "FRAMEWORK_SEARCH_PATHS": "$(inherited) $(PODS_ROOT)/UBiXMediationSDK/**",
    "HEADER_SEARCH_PATHS": "$(inherited) $(PODS_ROOT)/UBiXMediationSDK/**"
  },
  "dependencies": {
    "ToBid-iOS-RC": [
      "5.5.6"
    ],
    "UBiXMediationSDK": [
      "2.13.1"
    ],
    "UBiXMerakSDK": [
      "2.10.2.11"
    ]
  }
}
