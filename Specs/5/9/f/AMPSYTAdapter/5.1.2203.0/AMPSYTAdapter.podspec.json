{
  "name": "AMPSYTAdapter",
  "version": "5.1.2203.0",
  "summary": "AMPS 聚合 SDK 优推（YouTui）渠道适配器",
  "description": "AMPS 聚合 SDK 的优推广告渠道适配器，支持开屏、Banner、插屏、\n激励视频、信息流模板、Draw视频及统一原生广告类型。\n内部依赖 YouTuiAdSDK 2.20.3，宿主 App 无需单独引入。\n以二进制 XCFramework 分发，仅暴露 AMPSYTAdapter.h 公共头文件。",
  "homepage": "https://gitee.com/adscope_admin/AMPSYTAdapter.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Cookie": "lvjunxue@hubcloud.com.cn"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "static_framework": true,
  "source": {
    "git": "https://gitee.com/adscope_admin/AMPSYTAdapter.git",
    "tag": "5.1.2203.0"
  },
  "vendored_frameworks": "AMPSYTAdapter.xcframework",
  "dependencies": {
    "YouTuiAdSDK": [
      "2.20.3"
    ]
  },
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "$(inherited) -ObjC"
  }
}
