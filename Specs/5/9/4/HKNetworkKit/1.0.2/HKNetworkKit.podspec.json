{
  "name": "HKNetworkKit",
  "version": "1.0.2",
  "summary": "A modern, dependency-free Swift networking toolkit (async/await), plus optional image loading and keyboard handling.",
  "description": "HKNetworkKit is a production-ready, URLSession-based networking framework built\non async/await, with retries, interceptors, auth, SSL pinning and reachability.\nOptional modules add SDWebImage-style image loading and IQKeyboardManager-style\nkeyboard handling — all with zero third-party dependencies.",
  "homepage": "https://github.com/harsh-171095/HKNetworkKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Harsh Kadiya": "harsh171095@gmail.com"
  },
  "source": {
    "git": "https://github.com/harsh-171095/HKNetworkKit.git",
    "tag": "1.0.2"
  },
  "swift_versions": [
    "6.0"
  ],
  "platforms": {
    "ios": "15.0",
    "osx": "12.0"
  },
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Core",
      "source_files": "Sources/HKNetworkKit/**/*.swift",
      "frameworks": [
        "Foundation",
        "Security",
        "CryptoKit",
        "Network"
      ]
    },
    {
      "name": "Image",
      "dependencies": {
        "HKNetworkKit/Core": [

        ]
      },
      "source_files": "Sources/HKNetworkKitImage/**/*.swift",
      "frameworks": "CryptoKit",
      "ios": {
        "frameworks": "UIKit"
      },
      "osx": {
        "frameworks": "AppKit"
      }
    },
    {
      "name": "Keyboard",
      "source_files": "Sources/KeyboardKit/**/*.swift",
      "ios": {
        "frameworks": "UIKit"
      }
    }
  ],
  "swift_version": "6.0"
}
