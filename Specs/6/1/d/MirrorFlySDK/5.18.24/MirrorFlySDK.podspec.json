{
  "name": "MirrorFlySDK",
  "version": "5.18.24",
  "summary": "MirrorFly iOS SDK — Real-time chat, voice & video calling SDK.",
  "description": "MirrorFly iOS SDK provides real-time messaging, voice calling, and video calling\ncapabilities. This SDK includes prebuilt UI components and APIs to integrate\nchat and calling features into your iOS application.",
  "homepage": "https://github.com/MirrorFly/Mirrorfly-ios-framework",
  "documentation_url": "https://www.mirrorfly.com/docs/chat/ios/v2/quick-start/",
  "authors": {
    "Vishvanath": "vishvanatheshwer.v@contus.in",
    "Vanitha": "vanitha.g@contus.in"
  },
  "license": {
    "type": "Commercial",
    "file": "LICENSE"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "source": {
    "git": "https://github.com/MirrorFly/Mirrorfly-ios-framework.git",
    "tag": "5.18.24"
  },
  "ios": {
    "frameworks": [
      "UIKit"
    ]
  },
  "dependencies": {
    "libPhoneNumber-iOS": [
      "0.9.15"
    ],
    "Alamofire": [
      "5.9.1"
    ],
    "SocketRocket": [
      "0.7.1"
    ],
    "Socket.IO-Client-Swift": [
      "16.1.1"
    ],
    "Starscream": [
      "4.0.8"
    ],
    "RealmSwift": [
      "~> 10.54.2"
    ],
    "GoogleWebRTC": [
      "1.1.31999"
    ],
    "CocoaLumberjack": [
      "3.6.2"
    ],
    "XMPPFramework/Swift": [
      "4.0.0"
    ],
    "IDZSwiftCommonCrypto": [
      "~> 0.16"
    ]
  },
  "pod_target_xcconfig": {
    "VALID_ARCHS": "arm64 x86_64",
    "IPHONEOS_DEPLOYMENT_TARGET": "13.0",
    "SWIFT_VERSION": "5.0",
    "SWIFT_SUPPRESS_WARNINGS": "YES"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "swift_version": "5.0"
}
