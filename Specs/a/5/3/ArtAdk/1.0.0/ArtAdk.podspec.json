{
  "name": "ArtAdk",
  "version": "1.0.0",
  "summary": "Objective-C ADK for ART - A Realtime Tech Communication.",
  "description": "Objective-C ADK for ART, a realtime messaging platform providing WebSocket-based channels, \npresence tracking, end-to-end encrypted messaging, and CRDT-backed shared objects.",
  "homepage": "https://arealtimetech.com/",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "AIOTRIX DEVELOPERS": "aiotrix.dev@gmail.com"
  },
  "source": {
    "git": "https://github.com/aiotrixdev/art-objectivec-adk.git",
    "tag": "1.0.0"
  },
  "platforms": {
    "ios": "15.0",
    "osx": "10.15"
  },
  "source_files": "Sources/ADK/**/*.{h,m,c,mm,cpp}",
  "public_header_files": "Sources/ADK/**/*.h",
  "header_mappings_dir": "Sources/ADK",
  "pod_target_xcconfig": {
    "GCC_C_LANGUAGE_STANDARD": "gnu17",
    "HEADER_SEARCH_PATHS": "$(inherited) \"${PODS_TARGET_SRCROOT}/Sources/ADK/Auth\" \"${PODS_TARGET_SRCROOT}/Sources/ADK/Config\" \"${PODS_TARGET_SRCROOT}/Sources/ADK/CRDT\" \"${PODS_TARGET_SRCROOT}/Sources/ADK/Crypto\" \"${PODS_TARGET_SRCROOT}/Sources/ADK/Crypto/TweetNaCl\" \"${PODS_TARGET_SRCROOT}/Sources/ADK/Types\" \"${PODS_TARGET_SRCROOT}/Sources/ADK/WebSocket\""
  }
}
