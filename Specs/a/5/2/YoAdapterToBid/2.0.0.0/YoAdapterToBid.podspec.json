{
  "name": "YoAdapterToBid",
  "version": "2.0.0.0",
  "summary": "YoAdapterToBid 是一个纵量广告 iOS 平台的广告聚合 SDK",
  "description": "YoAdapterToBid 是纵量广告针对 ToBid 的自定义广告的适配器。",
  "homepage": "https://gitee.com/ZongLiangSDK/",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "ZongLiang": "sdk@zonglianglm.com"
  },
  "source": {
    "git": "https://gitee.com/ZongLiangSDK/YoAdapterToBid.git",
    "tag": "2.0.0.0"
  },
  "platforms": {
    "ios": "12.0"
  },
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "vendored_frameworks": [
    "YoAdapterToBid/YoAdapterToBid.xcframework"
  ],
  "frameworks": [
    "UIKit",
    "Foundation",
    "CoreAudio",
    "AudioToolbox",
    "AVFoundation"
  ],
  "dependencies": {
    "YoAdCore": [
      ">= 2.0.0.0"
    ],
    "ToBid-iOS": [
      "<= 4.7.0"
    ]
  }
}
