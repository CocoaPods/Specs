{
  "name": "ApplePay-iOS",
  "version": "0.0.7",
  "summary": "A comprehensive Apple Pay integration library for iOS",
  "description": "ApplePay-iOS is a robust library that simplifies Apple Pay integration in iOS applications.\nIt provides secure payment processing, 3D Secure support, and comprehensive callback handling.",
  "homepage": "https://github.com/Tap-Payments/ApplePay-iOS",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Tap Payments": "support@tap.company"
  },
  "social_media_url": "https://twitter.com/tappayments",
  "platforms": {
    "ios": "16.0"
  },
  "source": {
    "git": "https://github.com/Tap-Payments/ApplePay-iOS.git",
    "tag": "0.0.7"
  },
  "source_files": "Sources/ApplePay-iOS/**/*.swift",
  "resources": "Sources/ApplePay-iOS/Resources/*.json",
  "dependencies": {
    "SwiftyRSA": [
      ">= 1.0.0"
    ],
    "SharedDataModels-iOS": [
      ">= 0.0.1"
    ],
    "TapApplePayKit-iOS": [
      ">= 1.0.32"
    ]
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "frameworks": [
    "UIKit",
    "Foundation",
    "PassKit",
    "WebKit"
  ],
  "pod_target_xcconfig": {
    "SWIFT_VERSION": "5.0",
    "ENABLE_BITCODE": "NO"
  },
  "swift_version": "5.0"
}
