{
  "name": "CleverTapNativeDisplay",
  "version": "1.0.0",
  "summary": "Server-driven UI framework for native mobile interfaces",
  "description": "CleverTapNativeDisplay is a server-driven UI framework that renders native\nSwiftUI interfaces from JSON configurations. It supports dynamic layouts,\nstyling, galleries, background effects, and variable interpolation.",
  "homepage": "https://github.com/CleverTap/clevertap-native-ui-kit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "CleverTap": "support@clevertap.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.5",
  "source": {
    "git": "https://github.com/CleverTap/clevertap-native-ui-kit.git",
    "tag": "1.0.0"
  },
  "source_files": "ios/Sources/CleverTapNativeDisplay/**/*.swift",
  "resource_bundles": {
    "CleverTapNativeDisplay": [
      "ios/Sources/CleverTapNativeDisplay/PrivacyInfo.xcprivacy"
    ]
  },
  "frameworks": [
    "SwiftUI",
    "Foundation",
    "UIKit",
    "WebKit",
    "AVKit"
  ],
  "pod_target_xcconfig": {
    "BUILD_LIBRARY_FOR_DISTRIBUTION": "YES",
    "DEFINES_MODULE": "YES"
  },
  "swift_version": "5.5"
}
