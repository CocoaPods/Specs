{
  "name": "iosSdkLibraryAppendix",
  "version": "0.2.0",
  "summary": "A Swift library supporting R89SDK by handling iOS-specific features.",
  "description": "iosSdkLibraryAppendix complements R89SDK by enabling features that require Swift or Objective-C: which are unsupported in Kotlin Multiplatform.",
  "homepage": "https://refinery89.com/monetize-app-sdk/",
  "license": {
    "type": "No License",
    "file": "LICENSE"
  },
  "authors": {
    "Ankush Kumar": "ankush@refinery89.com",
    "Dmitriy Tskitishvili": "dmitriy@refinery89.com",
    "Robert Apikyan": "robert.apikyan@refinery89.com"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://bitbucket.org/xgn/iossdklibraryappendix.git",
    "tag": "0.2.0"
  },
  "platforms": {
    "ios": "13.0"
  },
  "static_framework": true,
  "dependencies": {
    "PrebidMobile": [
      "~> 3.0.0"
    ],
    "PrebidMobileAdMobAdapters": [
      "~> 3.0.0"
    ]
  },
  "vendored_frameworks": "iosSdkLibraryAppendix.xcframework",
  "source_files": [
    "iosSdkLibraryAppendix.xcframework/ios-arm64/iosSdkLibraryAppendix.framework/Headers/*.h",
    "iosSdkLibraryAppendix.xcframework/ios-arm64_x86_64-simulator/iosSdkLibraryAppendix.framework/Headers/*.h"
  ],
  "public_header_files": [
    "iosSdkLibraryAppendix.xcframework/ios-arm64/iosSdkLibraryAppendix.framework/Headers/*.h",
    "iosSdkLibraryAppendix.xcframework/ios-arm64_x86_64-simulator/iosSdkLibraryAppendix.framework/Headers/*.h"
  ],
  "swift_version": "5.0"
}
