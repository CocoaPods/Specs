{
  "name": "LitemobTakuAdapter",
  "version": "1.0.2",
  "summary": "LitemobTakuAdapter - LitemobAd 的 Taku/AnyThink 适配器",
  "description": "LitemobTakuAdapter 是 LitemobAd 的聚合平台适配器，用于将 LitemobAd 接入到 Taku/AnyThink SDK。",
  "homepage": "https://hub.litemob.com/adsdk/ios-sdk",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Litemob": "sdk@litemob.com"
  },
  "source": {
    "git": "https://hub.litemob.com/adsdk/ios-sdk.git",
    "tag": "TakuAdapter-v1.0.2"
  },
  "platforms": {
    "ios": "11.0"
  },
  "requires_arc": true,
  "static_framework": true,
  "source_files": "LitemobTakuAdapter/**/*.{h,m}",
  "public_header_files": "LitemobTakuAdapter/**/*.h",
  "dependencies": {
    "LitemobAd": [
      "1.2.4"
    ],
    "AnyThinkiOS": [
      "6.5.45"
    ],
    "AnyThinkMediationAdxSmartdigimktCNAdapter": [
      "6.5.66.0"
    ]
  },
  "frameworks": [
    "Foundation",
    "UIKit"
  ],
  "pod_target_xcconfig": {
    "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
  }
}
