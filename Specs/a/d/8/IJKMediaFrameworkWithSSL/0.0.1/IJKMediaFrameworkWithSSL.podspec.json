{
  "name": "IJKMediaFrameworkWithSSL",
  "version": "0.0.1",
  "summary": "IJKPlayer with SSL support.",
  "description": "使用 github 代码编译的 IJKPlayer 动态库",
  "homepage": "https://github.com/fionaly89/IJKMediaFrameworkWithSSL",
  "license": "LICENSE",
  "authors": {
    "fionaly89": "liyue271181776@gmail.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "source": {
    "git": "https://github.com/fionaly89/IJKMediaFrameworkWithSSL.git",
    "tag": "0.0.1"
  },
  "source_files": "Classes/IJKMediaFrameworkWithSSL.framework/Headers/*.{h,m}",
  "exclude_files": "Classes/Exclude",
  "ios": {
    "vendored_frameworks": "Classes/IJKMediaFrameworkWithSSL.framework"
  },
  "public_header_files": "Classes/IJKMediaFrameworkWithSSL.framework/Headers/*.h",
  "frameworks": [
    "Foundation",
    "UIKit",
    "AVFoundation",
    "CoreGraphics",
    "MobileCoreServices"
  ],
  "libraries": [
    "z",
    "bz2",
    "c++"
  ],
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  }
}
