{
  "name": "NosmaiModerationSDK",
  "version": "1.0.1",
  "summary": "On-device content + text moderation for iOS — image, video, text and live camera.",
  "description": "Nosmai Moderation is a closed-source iOS SDK for on-device content moderation:\nobject detection (weapon / drug / cigarette / alcohol), NSFW classification, and\nchat text moderation. Runs fully offline — no frame or message leaves the device.\n\nRegister a project in the Nosmai portal to obtain a license key, used to\ninitialize the SDK.",
  "homepage": "https://github.com/nosmai/moderation-sdk-ios",
  "license": {
    "type": "Proprietary",
    "text": "See LICENSE file"
  },
  "authors": {
    "Nosmai": "admin@nosmai.com"
  },
  "platforms": {
    "ios": "15.1"
  },
  "source": {
    "http": "https://github.com/nosmai/moderation-sdk-ios/releases/download/1.0.1/NosmaiModerationSDK.zip"
  },
  "preserve_paths": [
    "NosmaiDetection.xcframework/**/*",
    "onnxruntime/**/*"
  ],
  "resources": "Models/*",
  "resource_bundles": {
    "NosmaiModerationSDK_privacy": [
      "PrivacyInfo.xcprivacy"
    ]
  },
  "static_framework": true,
  "frameworks": [
    "CoreML",
    "Vision",
    "CoreVideo",
    "Accelerate",
    "AVFoundation",
    "CoreMedia",
    "CoreGraphics",
    "UIKit"
  ],
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64",
    "NOSMAI_SLICE[sdk=iphoneos*]": "ios-arm64",
    "NOSMAI_SLICE[sdk=iphonesimulator*]": "ios-arm64-simulator",
    "HEADER_SEARCH_PATHS": "$(inherited) \"$(PODS_ROOT)/NosmaiModerationSDK/NosmaiDetection.xcframework/$(NOSMAI_SLICE)/Headers\"",
    "SWIFT_INCLUDE_PATHS": "$(inherited) \"$(PODS_ROOT)/NosmaiModerationSDK/NosmaiDetection.xcframework/$(NOSMAI_SLICE)/Headers\"",
    "OTHER_LDFLAGS": "$(inherited) -lc++ -L\"$(PODS_ROOT)/NosmaiModerationSDK/NosmaiDetection.xcframework/$(NOSMAI_SLICE)\" -lNosmaiMerged -force_load \"$(PODS_ROOT)/NosmaiModerationSDK/onnxruntime/$(NOSMAI_SLICE)/libonnxruntime.a\""
  },
  "swift_versions": "5.0",
  "swift_version": "5.0"
}
