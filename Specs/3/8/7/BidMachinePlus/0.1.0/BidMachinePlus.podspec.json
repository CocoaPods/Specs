{
  "name": "BidMachinePlus",
  "version": "0.1.0",
  "summary": "BidMachinePlus iOS SDK",
  "description": "BidMachinePlus is the next generation BidMachine SDK with built-in mediation.",
  "homepage": "https://bidmachine.io",
  "license": {
    "type": "Commercial",
    "text": "https://bidmachine.io/sdk-license-agreement/"
  },
  "authors": {
    "BidMachine": "https://bidmachine.io"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": [
    "5.9"
  ],
  "source": {
    "http": "https://bidmachine-ios.s3.amazonaws.com/BidMachinePlus/0.1.0/pod/BidMachinePlus.zip"
  },
  "default_subspecs": "Static",
  "subspecs": [
    {
      "name": "Static",
      "vendored_frameworks": "release/Static/BidMachinePlus.xcframework",
      "user_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      },
      "dependencies": {
        "BidMachine/Static": [
          "3.7.1"
        ],
        "Bidon": [
          "0.15.0"
        ],
        "BidonAdapterBidMachine": [
          "3.7.1.2"
        ]
      }
    },
    {
      "name": "Dynamic",
      "vendored_frameworks": "release/Dynamic/BidMachinePlus.xcframework",
      "dependencies": {
        "BidMachine/Dynamic": [
          "3.7.1"
        ],
        "Bidon": [
          "0.15.0"
        ],
        "BidonAdapterBidMachine/Dynamic": [
          "3.7.1.2"
        ]
      }
    }
  ],
  "swift_version": "5.9"
}
