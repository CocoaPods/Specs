{
  "name": "BideaseSDK",
  "version": "0.0.1",
  "platforms": {
    "ios": "13.0"
  },
  "summary": "Bidease - advertising solutions",
  "description": "Bidease - advertising solutions",
  "homepage": "https://bidease.com",
  "license": {
    "type": "Proprietary",
    "text": "Copyright Bidease"
  },
  "authors": {
    "Bidease": "be-sdk@bidease.com"
  },
  "source": {
    "http": "https://sdk.bidease.com/ios/BideaseMobileSDK_0.0.1.zip"
  },
  "swift_versions": "5.0",
  "static_framework": true,
  "default_subspecs": "MobileAds",
  "subspecs": [
    {
      "name": "MobileAds",
      "vendored_frameworks": [
        "BideaseMobileSDK.xcframework",
        "BideaseCore.xcframework"
      ],
      "resource_bundles": {
        "BideaseMobileResources": [
          "BideaseMobileResources.bundle/*.{js,json}"
        ]
      },
      "pod_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      },
      "user_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      }
    },
    {
      "name": "AdapterAdmob",
      "vendored_frameworks": "BideaseAdapterAdmob.xcframework",
      "dependencies": {
        "Google-Mobile-Ads-SDK": [

        ],
        "BideaseSDK/MobileAds": [

        ]
      },
      "pod_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      },
      "user_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      }
    },
    {
      "name": "TestMode",
      "vendored_frameworks": "BideaseMobileTestMode.xcframework",
      "pod_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      },
      "user_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      }
    }
  ],
  "swift_version": "5.0"
}
