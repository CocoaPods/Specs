{
  "name": "BrainCloud",
  "version": "6.0.0",
  "summary": "The Objective-C/Swift client library for brainCloud.",
  "homepage": "http://getbraincloud.com/",
  "platforms": {
    "ios": "15.0",
    "osx": "13.0",
    "tvos": "15.0",
    "visionos": "1.0",
    "watchos": "8.0"
  },
  "license": {
    "type": "Apache License, Version 2.0",
    "file": "LICENSE"
  },
  "authors": {
    "brainCloud Team": "support@getbraincloud.com"
  },
  "source": {
    "git": "https://github.com/getbraincloud/braincloud-objc.git",
    "tag": "6.0.0"
  },
  "header_mappings_dir": "Shared",
  "public_header_files": "Shared/**/*.{h,hh}",
  "private_header_files": "Shared/**/{BrainCloudCallback,TypeHelpers,BrainCloudRTTCallback,BrainCloudRTTConnectCallback,BrainCloudRelayCallback,BrainCloudRelaySystemCallback,BrainCloudRelayConnectCallback}.hh",
  "source_files": "Shared/**/*.{h,hh,m,mm}",
  "xcconfig": {
    "USER_HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/BrainCloudCpp/include\" \"${PODS_ROOT}/BrainCloudCpp/include/braincloud/internal/apple\""
  },
  "dependencies": {
    "BrainCloudCpp": [
      "6.0.0"
    ]
  }
}
