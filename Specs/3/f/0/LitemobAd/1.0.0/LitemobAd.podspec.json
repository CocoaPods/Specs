{
  "name": "LitemobAd",
  "version": "1.0.0",
  "summary": "LitemobAd - 轻量级移动广告SDK",
  "description": "LitemobAd 是一个轻量级的iOS广告SDK，支持多种广告形式。\n宿主只需 pod 'LitemobAd' 即可集成全部。",
  "homepage": "https://hub.litemob.com/adsdk/ios-sdk",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Litemob": "sdk@litemob.com"
  },
  "source": {
    "git": "https://hub.litemob.com/adsdk/ios-sdk.git",
    "tag": "v1.0.0"
  },
  "platforms": {
    "ios": "11.0"
  },
  "requires_arc": true,
  "vendored_frameworks": [
    "LitemobAd.xcframework",
    "LitemobAdLib01.xcframework",
    "LitemobAdLib02.xcframework",
    "LitemobAdLib03.xcframework",
    "LitemobAdLib04.xcframework",
    "LitemobAdLib05.xcframework",
    "LitemobAdLib06.xcframework"
  ],
  "resources": [
    "Resources/LTAdSDK.bundle",
    "Resources/LMAd1.bundle"
  ],
  "frameworks": [
    "Foundation",
    "UIKit",
    "WebKit",
    "AVFoundation",
    "StoreKit",
    "CoreGraphics",
    "QuartzCore",
    "CoreMotion",
    "Accelerate",
    "SystemConfiguration",
    "MobileCoreServices",
    "ImageIO",
    "Security"
  ],
  "weak_frameworks": [
    "CoreLocation",
    "CoreTelephony",
    "AdSupport",
    "AppTrackingTransparency"
  ],
  "libraries": [
    "z",
    "c++",
    "sqlite3",
    "xml2"
  ],
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  }
}
