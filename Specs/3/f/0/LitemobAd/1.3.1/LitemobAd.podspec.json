{
  "name": "LitemobAd",
  "version": "1.3.1",
  "summary": "LitemobAd - 轻量级移动广告SDK（Core Only）",
  "description": "LitemobAd Core 版本，不含第三方 ADN SDK。供聚合平台适配器集成使用。",
  "homepage": "https://hub.litemob.com/adsdk/ios-sdk",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Litemob": "sdk@litemob.com"
  },
  "source": {
    "git": "https://hub.litemob.com/adsdk/ios-sdk.git",
    "tag": "v1.3.1"
  },
  "platforms": {
    "ios": "11.0"
  },
  "requires_arc": true,
  "static_framework": true,
  "vendored_frameworks": [
    "LitemobAd.xcframework",
    "LitemobAdLib01.xcframework",
    "LitemobAdLib05.xcframework",
    "LitemobAdLib07.xcframework",
    "LmbAdSDK.xcframework"
  ],
  "resources": [
    "Resources/FSUnionAdSDK.bundle",
    "Resources/SYLTAd.bundle",
    "Resources/LmbAdSDK.bundle"
  ],
  "frameworks": [
    "Foundation",
    "UIKit",
    "WebKit",
    "AVFoundation",
    "StoreKit",
    "CoreGraphics",
    "QuartzCore",
    "CoreMotion",
    "Accelerate",
    "SystemConfiguration",
    "MobileCoreServices",
    "ImageIO",
    "Security"
  ],
  "weak_frameworks": [
    "CoreLocation",
    "CoreTelephony",
    "AdSupport",
    "AppTrackingTransparency"
  ],
  "libraries": [
    "z",
    "c++",
    "sqlite3",
    "xml2"
  ],
  "swift_versions": [
    "5"
  ],
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "user_target_xcconfig": {
    "ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES": "YES",
    "LIBRARY_SEARCH_PATHS": "$(inherited) \"${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}\" /usr/lib/swift"
  },
  "swift_version": "5"
}
