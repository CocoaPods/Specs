{
  "name": "LaunchDarklySessionReplay",
  "version": "0.29.0",
  "summary": "iOS Session Replay Plugin for LaunchDarkly.",
  "description": "LaunchDarkly is the feature management platform that software teams use to build better software, faster.",
  "homepage": "https://github.com/launchdarkly/swift-launchdarkly-observability",
  "license": {
    "type": "Apache License, Version 2.0",
    "file": "LICENSE.txt"
  },
  "authors": {
    "LaunchDarkly": "sdks@launchdarkly.com"
  },
  "platforms": {
    "ios": "13.0"
  },
  "source": {
    "git": "https://github.com/launchdarkly/swift-launchdarkly-observability.git",
    "tag": "0.29.0"
  },
  "swift_versions": "5.9",
  "default_subspecs": "LaunchDarklySessionReplay",
  "pod_target_xcconfig": {
    "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "$(inherited) LD_COCOAPODS"
  },
  "user_target_xcconfig": {
    "ENABLE_USER_SCRIPT_SANDBOXING": "NO"
  },
  "subspecs": [
    {
      "name": "SessionReplayC",
      "vendored_frameworks": "Frameworks/SessionReplayC.xcframework"
    },
    {
      "name": "LaunchDarklySessionReplay",
      "source_files": "Sources/LaunchDarklySessionReplay/**/*.{swift,h,m}",
      "pod_target_xcconfig": {
        "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "$(inherited) LD_COCOAPODS",
        "OTHER_SWIFT_FLAGS": "$(inherited) -package-name LaunchDarklyObservability"
      },
      "dependencies": {
        "LaunchDarklySessionReplay/SessionReplayC": [

        ],
        "LaunchDarklyObservability": [

        ]
      }
    }
  ],
  "swift_version": "5.9"
}
