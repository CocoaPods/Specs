{
  "name": "AddiMobile-FraudForce",
  "version": "5.8.0",
  "summary": "TransUnion TruValidate Device Risk SDK for iOS (formerly FraudForce)",
  "description": "Device Risk SDK for iOS, formerly known as FraudForce, provides device-based risk detection for fraud and identity solutions. It inspects the device and generates a blackbox for risk assessment. Integrates with native and hybrid apps.",
  "homepage": "https://github.com/AdelanteFinancialHoldings/deviceprint-SDK-iOS",
  "license": {
    "type": "Commercial",
    "file": "LICENSE.txt"
  },
  "authors": {
    "iovation, a TransUnion company": "support@iovation.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "source": {
    "git": "https://github.com/AdelanteFinancialHoldings/deviceprint-SDK-iOS.git",
    "tag": "5.8.0"
  },
  "vendored_frameworks": "FraudForce.xcframework",
  "frameworks": [
    "CoreTelephony",
    "Security",
    "SystemConfiguration"
  ],
  "weak_frameworks": [
    "AdSupport",
    "CoreLocation"
  ],
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "requires_arc": true,
  "module_name": "FraudForce",
  "documentation_url": "https://github.com/AdelanteFinancialHoldings/deviceprint-SDK-iOS"
}
