{
  "name": "TeslaBLEKeyKit",
  "version": "0.1.0",
  "summary": "Swift library for communicating with Tesla vehicles over BLE.",
  "description": "TeslaBLEKeyKit wraps the BLE transport, universal-message session\nauthentication, and VCSEC commands for talking to Tesla vehicles\nover the local BLE command protocol.",
  "homepage": "https://github.com/misakatao/TeslaBLEKeyKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "misakatao": "misakatao@gmail.com"
  },
  "source": {
    "git": "https://github.com/misakatao/TeslaBLEKeyKit.git",
    "tag": "0.1.0"
  },
  "platforms": {
    "ios": "16.0",
    "osx": "13.0"
  },
  "swift_versions": [
    "5.9",
    "5.10"
  ],
  "source_files": "Sources/**/*.swift",
  "exclude_files": "Sources/**/Protos/**",
  "resource_bundles": {
    "TeslaBLEKeyKit": [
      "Sources/TeslaBLEKeyKit/PrivacyInfo.xcprivacy"
    ]
  },
  "frameworks": [
    "CoreBluetooth",
    "Security"
  ],
  "dependencies": {
    "SwiftProtobuf": [
      "~> 1.28"
    ]
  },
  "swift_version": "5.10"
}
