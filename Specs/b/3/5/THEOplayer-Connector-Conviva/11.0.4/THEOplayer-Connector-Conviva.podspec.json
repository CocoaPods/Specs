{
  "name": "THEOplayer-Connector-Conviva",
  "module_name": "THEOplayerConnectorConviva",
  "version": "11.0.4",
  "summary": "Integration between the THEOplayerSDK and ConvivaSDK",
  "description": "This pod gives you access to classes that let you report playback events from a THEOplayer instance to Conviva",
  "homepage": "https://github.com/THEOplayer/iOS-Connector",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": "THEO technologies",
  "source": {
    "git": "https://github.com/THEOplayer/iOS-Connector.git",
    "tag": "11.0.4"
  },
  "platforms": {
    "ios": "15.0",
    "tvos": "15.0"
  },
  "static_framework": true,
  "swift_versions": [
    "5.3",
    "5.4",
    "5.5",
    "5.6",
    "5.7"
  ],
  "default_subspecs": [
    "Base",
    "THEOlive"
  ],
  "subspecs": [
    {
      "name": "Base",
      "source_files": "Code/Conviva/Source/Base/**/*",
      "dependencies": {
        "ConvivaSDK": [
          "~> 4.3.1"
        ],
        "THEOplayerSDK-core": [
          "~> 11"
        ],
        "THEOplayer-Connector-Utilities": [
          "~> 11.0",
          ">= 11.0.4"
        ]
      }
    },
    {
      "name": "THEOlive",
      "source_files": "Code/Conviva/Source/THEOlive/**/*",
      "dependencies": {
        "THEOplayer-Connector-Conviva/Base": [

        ],
        "THEOplayer-Integration-THEOlive": [
          "~> 11"
        ]
      }
    }
  ],
  "swift_version": "5.7"
}
