{
  "name": "HXSDK",
  "version": "5.1.8",
  "summary": "HXSDK for iOS.",
  "homepage": "https://gitee.com/octmon/hxsdk-ios.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "octmon": "octmon@qq.com"
  },
  "source": {
    "git": "https://gitee.com/octmon/hxsdk-ios.git",
    "tag": "5.1.8"
  },
  "platforms": {
    "ios": "11.0"
  },
  "default_subspecs": [
    "Core"
  ],
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "$(inherited) -ObjC"
  },
  "xcconfig": {
    "VALID_ARCHS": "armv7 armv7s x86_64 arm64"
  },
  "subspecs": [
    {
      "name": "Core",
      "vendored_frameworks": "HXSDK.framework",
      "source_files": "HXSDK.framework/Headers/*.h",
      "public_header_files": "HXSDK.framework/Headers/*.h"
    },
    {
      "name": "PTG",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "PTGAdFramework": [
          "~> 2.3.6"
        ]
      }
    },
    {
      "name": "UBiX",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "UBiXMerakSDK": [
          "~> 2.10.0.11"
        ]
      }
    },
    {
      "name": "Mobile",
      "dependencies": {
        "HXSDK/Core": [

        ]
      },
      "frameworks": "AdSupport",
      "vendored_frameworks": [
        "Frameworks/CJMobileAd/HX_CNCommonSDK.framework",
        "Frameworks/CJMobileAd/HX-CNSDK.framework",
        "Frameworks/CJMobileAd/JTAdSDK.xcframework",
        "Frameworks/CJMobileAd/JYAdSDK.xcframework"
      ],
      "resources": [
        "Frameworks/CJMobileAd/HX-CNSDK.bundle"
      ]
    },
    {
      "name": "Mobile-s",
