        "Frameworks/LH/LHAdvertisingID.xcframework"
      ],
      "resources": "Frameworks/LH/LHAdSDK.bundle"
    },
    {
      "name": "MS",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "MSMobAdSDKv3/MS": [
          "~> 3.0.10.2"
        ]
      }
    },
    {
      "name": "YT",
      "dependencies": {
        "HXSDK/Core": [

        ]
      },
      "vendored_frameworks": [
        "Frameworks/YouTuiAd/YouTuiAdSDK.xcframework",
        "Frameworks/YouTuiAd/YTRelayFoundation.xcframework"
      ],
      "resources": "Frameworks/YouTuiAd/YouTuiAdSDK.bundle"
    },
    {
      "name": "BZ",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "BeiZiSDK-iOS": [
          "5.0.0.1"
        ]
