        "Frameworks/JT/lingst.framework"
      ]
    },
    {
      "name": "RS",
      "dependencies": {
        "HXSDK/Core": [

        ]
      },
      "vendored_frameworks": [
        "Frameworks/RS/MentaUnifiedSDK.xcframework",
        "Frameworks/RS/MentaVlionAdapter.xcframework",
        "Frameworks/RS/MentaVlionBaseSDK.xcframework",
        "Frameworks/RS/MentaVlionSDK.xcframework"
      ],
      "resources": [
        "Frameworks/RS/MVBaseSDK.bundle"
      ]
    }
