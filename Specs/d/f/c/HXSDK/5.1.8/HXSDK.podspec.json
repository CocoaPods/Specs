    {
      "name": "Richmob",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "RichmobAdSDK": [
          "1.2.3.2-ling"
        ]
      },
      "user_target_xcconfig": {
        "ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES": "YES",
        "LD_RUNPATH_SEARCH_PATHS": "$(inherited) /usr/lib/swift",
        "LIBRARY_SEARCH_PATHS": "$(inherited) $(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME) /usr/lib/swift"
      }
    },
    {
      "name": "HRichmob",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "RichmobAdSDK": [
          "1.2.3.1-hxad"
        ]
      },
      "user_target_xcconfig": {
        "ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES": "YES",
        "LD_RUNPATH_SEARCH_PATHS": "$(inherited) /usr/lib/swift",
        "LIBRARY_SEARCH_PATHS": "$(inherited) $(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME) /usr/lib/swift"
      }
    },
    {
