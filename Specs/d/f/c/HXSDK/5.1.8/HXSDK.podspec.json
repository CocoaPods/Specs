      "frameworks": "AdSupport",
      "vendored_frameworks": [
        "Frameworks/CJMobileAd-s/HX_CNCommonSDK.framework",
        "Frameworks/CJMobileAd-s/LingYeAdSDK.framework",
        "Frameworks/CJMobileAd-s/LYJTAdSDK.xcframework",
        "Frameworks/CJMobileAd-s/JYAdSDK.xcframework"
      ],
      "resources": [
        "Frameworks/CJMobileAd-s/LingYeAdSDK.bundle"
      ]
    },
    {
      "name": "IconAd",
      "dependencies": {
        "HXSDK/Core": [

        ],
        "CXHAdSDK/ChannelNoWechat": [
          "~> 1.10.6"
        ],
        "CXHAdSDK/RC": [
          "~> 1.10.6 "
        ]
      }
    },
    {
      "name": "LH",
      "dependencies": {
        "HXSDK/Core": [

