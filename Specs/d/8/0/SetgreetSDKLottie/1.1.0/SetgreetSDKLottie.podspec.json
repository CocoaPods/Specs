{
  "name": "SetgreetSDKLottie",
  "version": "1.1.0",
  "summary": "Optional Lottie animation support for the Setgreet iOS SDK.",
  "description": "Adds Lottie animation rendering to the Setgreet iOS SDK.\nInstall this pod only if your Setgreet flows use Lottie\nanimation components. The core SetgreetSDK pod carries no\nLottie dependency; this companion brings in lottie-ios and\nregisters the Lottie component at runtime via\n`SetgreetLottie.register()`.",
  "homepage": "https://setgreet.com",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Setgreet": "support@setgreet.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "source": {
    "git": "https://github.com/setgreet/setgreet-ios-sdk.git",
    "tag": "1.1.0"
  },
  "vendored_frameworks": "SetgreetSDKLottie.xcframework",
  "source_files": "SetgreetSDKLottie.xcframework/**/*.h",
  "preserve_paths": "SetgreetSDKLottie.xcframework",
  "frameworks": [
    "UIKit",
    "Foundation"
  ],
  "dependencies": {
    "SetgreetSDK": [
      "1.1.0"
    ],
    "lottie-ios": [
      "~> 4.6"
    ]
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "pod_target_xcconfig": {
    "FRAMEWORK_SEARCH_PATHS": "$(PODS_ROOT)/SetgreetSDKLottie",
    "OTHER_LDFLAGS": "$(inherited) -framework SetgreetSDKLottie"
  },
  "user_target_xcconfig": {
    "FRAMEWORK_SEARCH_PATHS": "$(PODS_ROOT)/SetgreetSDKLottie",
    "OTHER_LDFLAGS": "$(inherited) -framework SetgreetSDKLottie"
  },
  "swift_version": "5.0"
}
