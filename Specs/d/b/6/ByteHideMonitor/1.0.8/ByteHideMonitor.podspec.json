    "ByteHide": "support@bytehide.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "source": {
    "http": "https://github.com/bytehide/ByteHideMonitor-iOS/releases/download/v1.0.8/ByteHideMonitor.xcframework.zip",
    "type": "zip"
  },
  "vendored_frameworks": "ByteHideMonitor.xcframework",
  "preserve_paths": [
    "Scripts/sign-assembly.sh",
    "Scripts/setup.sh",
