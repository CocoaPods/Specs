{
  "name": "PrimerResources",
  "version": "2.51.0",
  "summary": "Resources for Primer SDK",
  "description": "Contains resources (images, localisations, etc) used by PrimerSDK.",
  "homepage": "https://www.primer.io",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Primer": "sdk@primer.io"
  },
  "source": {
    "git": "https://github.com/primer-io/primer-sdk-ios.git",
    "tag": "2.51.0"
  },
  "swift_versions": "5",
  "platforms": {
    "ios": "13.0"
  },
  "source_files": "Modules/PrimerResources/Sources/PrimerResources/**/*.swift",
  "ios": {
    "resource_bundles": {
      "PrimerResources": [
        "Modules/PrimerResources/Sources/PrimerResources/Resources/*.xcassets",
        "Modules/PrimerResources/Sources/PrimerResources/Resources/Localizable/**/*.strings",
        "Modules/PrimerResources/Sources/PrimerResources/Resources/Localizable/**/*.stringsdict",
        "Modules/PrimerResources/Sources/PrimerResources/Resources/Nibs/*",
        "Modules/PrimerResources/Sources/PrimerResources/Resources/JSONs/**/*.json"
      ]
    }
  },
  "swift_version": "5"
}
