{
  "name": "CloudXDigitalTurbineAdapter",
  "version": "3.4.2",
  "summary": "CloudX Digital Turbine Adapter - Static Framework",
  "description": "Digital Turbine / Fyber adapter for CloudX iOS SDK - binary distribution. Supports Banner, MREC, Interstitial, Rewarded, and Native ad formats.",
  "homepage": "https://github.com/cloudx-io/cloudx-ios",
  "license": {
    "type": "Business Source License 1.1"
  },
  "authors": {
    "CloudX": "support@cloudx.io"
  },
  "source": {
    "git": "https://github.com/cloudx-io/cloudx-ios.git",
    "tag": "v3.4.2"
  },
  "platforms": {
    "ios": "13.0"
  },
  "vendored_frameworks": "adapter-digitalturbine/CloudXDigitalTurbineAdapter.xcframework",
  "dependencies": {
