{
  "name": "CloudXGoogleWaterfallAdapter",
  "version": "3.4.2",
  "summary": "CloudX Google Waterfall Adapter - Static Framework",
  "description": "Google Waterfall adapter for CloudX iOS SDK - binary distribution. Supports Banner (320x50) and MREC (300x250) ad formats.",
  "homepage": "https://github.com/cloudx-io/cloudx-ios",
  "license": {
    "type": "Business Source License 1.1"
  },
  "authors": {
    "CloudX": "support@cloudx.io"
  },
  "source": {
    "git": "https://github.com/cloudx-io/cloudx-ios.git",
    "tag": "v3.4.2"
  },
  "platforms": {
    "ios": "13.0"
  },
  "vendored_frameworks": "adapter-googlewaterfall/CloudXGoogleWaterfallAdapter.xcframework",
  "dependencies": {
    "CloudXCore": [
      "3.4.2"
    ],
    "Google-Mobile-Ads-SDK": [
      "12.14.0"
    ]
  },
  "frameworks": [
    "AVFoundation",
    "AVKit",
    "AdSupport",
    "CoreGraphics",
    "CoreLocation",
    "CoreTelephony",
    "Foundation",
    "StoreKit",
    "SystemConfiguration",
    "UIKit",
    "WebKit"
  ],
  "weak_frameworks": [
    "GoogleMobileAds"
  ],
  "requires_arc": true,
  "static_framework": true,
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "swift_versions": [
    "5.0",
    "5.1",
    "5.2",
    "5.3",
    "5.4",
    "5.5",
    "5.6",
    "5.7",
    "5.8",
    "5.9",
    "6.0",
    "6.1",
    "6.2"
  ],
  "swift_version": "6.2"
}
