{
  "name": "VableAI",
  "version": "0.0.3",
  "summary": "Vable AI iOS SDK - Real-time voice chat with AI",
  "description": "Vable AI iOS SDK provides real-time AI voice chat capabilities with WebRTC,\nWebSocket messaging, and screen context scanning.",
  "homepage": "https://vable.ai",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Vable AI": "support@vable.ai"
  },
  "source": {
    "http": "https://github.com/vable-ai/vable-swift/releases/download/0.0.3/VableAI.xcframework.zip"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": [
    "5.0"
  ],
  "module_name": "VableAI",
  "vendored_frameworks": "VableAI.xcframework",
  "dependencies": {
    "WebRTC-lib": [
      "~> 125.0"
    ]
  },
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386",
    "FRAMEWORK_SEARCH_PATHS": "$(inherited) $(PODS_ROOT)/WebRTC-lib/WebRTC.xcframework/ios-arm64 $(PODS_ROOT)/WebRTC-lib/WebRTC.xcframework/ios-arm64_x86_64-simulator"
  },
  "swift_version": "5.0"
}
