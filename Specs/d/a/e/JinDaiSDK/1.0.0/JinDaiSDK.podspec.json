{
  "name": "JinDaiSDK",
  "version": "1.0.0",
  "summary": "JinDai广告聚合 SDK",
  "description": "JinDai广告SDK是一个专为移动应用开发者设计的广告聚合和收益优化平台。它能够帮助开发者通过多种广告形式提高应用内广告的填充率和eCPM（每千次展示成本），从而增加广告收入",
  "homepage": "https://github.com/konnitiha/JinDaiSDK.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "ad": "1053591151@qq.com"
  },
  "source": {
    "git": "https://github.com/konnitiha/JinDaiSDK.git",
    "tag": "1.0.0"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "frameworks": [
    "Foundation",
    "UIKit",
    "MobileCoreServices",
    "Security",
    "SystemConfiguration",
    "CoreTelephony",
    "AdSupport",
    "WebKit",
    "Accelerate",
    "CoreMotion",
    "StoreKit",
    "AVFoundation",
    "MediaPlayer",
    "CoreMedia",
    "CoreLocation",
    "AVKit",
    "CoreGraphics",
    "CoreImage",
    "AudioToolbox"
  ],
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": [
      "-lObjC"
    ],
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "libraries": [
    "z",
    "resolv.9",
    "sqlite3",
    "c++",
    "c++abi",
    "resolv"
  ],
  "pod_target_xcconfig": {
    "VALID_ARCHS": "x86_64 arm64"
  },
  "default_subspecs": "JinDaiSDK",
  "subspecs": [
    {
      "name": "JinDaiSDK",
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiSDK.framework",
      "resources": [
        "JinDaiSDK/JinDaiSDK.bundle"
      ]
    },
    {
      "name": "CsjAdapter",
      "dependencies": {
        "JinDaiSDK/JinDaiSDK": [

        ],
        "Ads-CN-Beta/BUAdSDK": [
          ">= 7.1.0.0"
        ],
        "Ads-CN-Beta/CSJMediation": [
          ">= 7.1.0.0"
        ]
      },
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiCsjAdapter.framework"
    },
    {
      "name": "GdtAdapter",
      "dependencies": {
        "JinDaiSDK/JinDaiSDK": [

        ],
        "GDTMobSDK": [
          ">= 4.15.50"
        ]
      },
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiGdtAdapter.framework"
    },
    {
      "name": "KsAdapter",
      "dependencies": {
        "JinDaiSDK/JinDaiSDK": [

        ],
        "KSAdSDK": [
          ">= 4.4.20.1"
        ]
      },
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiKsAdapter.framework"
    },
    {
      "name": "TanxAdapter",
      "dependencies": {
        "JinDaiSDK/JinDaiSDK": [

        ],
        "TanxSDK": [
          ">= 3.6.7"
        ]
      },
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiTanxAdapter.framework"
    },
    {
      "name": "BaiduAdapter",
      "dependencies": {
        "JinDaiSDK/JinDaiSDK": [

        ],
        "BaiduMobAdSDK": [
          ">= 5.391"
        ]
      },
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiBaiduAdapter.framework"
    },
    {
      "name": "JdAdapter",
      "dependencies": {
        "JinDaiSDK/JinDaiSDK": [

        ],
        "JADYun": [
          ">= 2.6.4"
        ]
      },
      "platforms": {
        "ios": "12.0"
      },
      "vendored_frameworks": "JinDaiSDK/JinDaiJdAdapter.framework"
    }
  ]
}
