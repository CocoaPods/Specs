{
  "name": "Freshpaint",
  "module_name": "FreshpaintSDK",
  "version": "0.5.0",
  "summary": "Integrate Freshpaint with your iOS App.",
  "description": "The Freshpaint iOS SDK for sending data from your iOS\napp into Freshpaint.",
  "homepage": "https://freshpaint.io/",
  "authors": {
    "Freshpaint": "michael@freshpaint.io"
  },
  "license": "MIT",
  "source": {
    "git": "https://github.com/freshpaint-io/freshpaint-ios.git",
    "tag": "0.5.0"
  },
  "platforms": {
    "ios": "15.1",
    "tvos": "9.0"
  },
  "ios": {
    "frameworks": "CoreTelephony",
    "weak_frameworks": [
      "AppTrackingTransparency",
      "AdServices"
    ]
  },
  "frameworks": [
    "Security",
    "StoreKit",
    "SystemConfiguration",
    "UIKit"
  ],
  "source_files": [
    "Freshpaint/Classes/**/*",
    "Freshpaint/Internal/**/*"
  ],
  "private_header_files": [
    "Freshpaint/Classes/FPAdClickIds.h",
    "Freshpaint/Classes/FPAttributionMiddleware.h",
    "Freshpaint/Internal/**/*.h"
  ]
}
