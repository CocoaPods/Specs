{
  "name": "Airship",
  "version": "20.6.2",
  "summary": "Airship iOS SDK",
  "documentation_url": "https://docs.airship.com/platform/ios",
  "homepage": "https://www.airship.com",
  "authors": {
    "Airship": "support@airship.com"
  },
  "license": {
    "type": "Apache License, Version 2.0",
    "file": "LICENSE"
  },
  "source": {
    "git": "https://github.com/urbanairship/ios-library.git",
    "tag": "20.6.2"
  },
  "module_name": "AirshipKit",
  "header_dir": "AirshipKit",
  "platforms": {
    "ios": "16.0",
    "tvos": "18.0",
    "watchos": "11.0"
  },
  "swift_versions": "6.0",
  "requires_arc": true,
  "default_subspecs": [
    "Basement",
    "Core",
    "Automation",
    "MessageCenter",
    "PreferenceCenter",
    "FeatureFlags"
  ],
  "subspecs": [
    {
      "name": "Basement",
      "source_files": "Airship/AirshipBasement/Source/**/*.{swift}"
    },
    {
      "name": "Core",
      "source_files": "Airship/AirshipCore/Source/**/*.{swift}",
      "resource_bundles": {
        "AirshipCoreResources": "Airship/AirshipCore/Resources/**/*"
      },
      "exclude_files": "Airship/AirshipCore/Resources/Info.plist",
      "dependencies": {
        "Airship/Basement": [

        ]
      }
    },
    {
      "name": "Automation",
      "ios": {
        "source_files": "Airship/AirshipAutomation/Source/**/*.{swift}",
        "resource_bundles": {
          "AirshipAutomationResources": "Airship/AirshipAutomation/Resources/**/*"
        }
      },
      "dependencies": {
        "Airship/Core": [

        ]
      }
    },
    {
      "name": "MessageCenter",
      "ios": {
        "source_files": "Airship/AirshipMessageCenter/Source/**/*.{swift}",
        "resource_bundles": {
          "AirshipMessageCenterResources": "Airship/AirshipMessageCenter/Resources/**/*"
        }
      },
      "dependencies": {
        "Airship/Core": [

        ]
      }
    },
    {
      "name": "PreferenceCenter",
      "ios": {
        "source_files": "Airship/AirshipPreferenceCenter/Source/**/*.{swift}"
      },
      "dependencies": {
        "Airship/Core": [

        ]
      }
    },
    {
      "name": "FeatureFlags",
      "ios": {
        "source_files": "Airship/AirshipFeatureFlags/Source/**/*.{swift}"
      },
      "dependencies": {
        "Airship/Core": [

        ]
      }
    },
    {
      "name": "ObjectiveC",
      "ios": {
        "source_files": "Airship/AirshipObjectiveC/Source/**/*.{swift}"
      },
      "dependencies": {
        "Airship/Core": [

        ],
        "Airship/Automation": [

        ],
        "Airship/MessageCenter": [

        ],
        "Airship/PreferenceCenter": [

        ],
        "Airship/FeatureFlags": [

        ]
      }
    }
  ],
  "swift_version": "6.0"
}
