{
  "name": "mParticle-UrbanAirship-19",
  "module_name": "mParticle_UrbanAirship",
  "version": "9.2.1",
  "summary": "Airship integration for mParticle",
  "description": "This is the Airship (Urban Airship) integration for mParticle.",
  "homepage": "https://www.mparticle.com",
  "license": {
    "type": "Apache 2.0",
    "file": "LICENSE"
  },
  "authors": {
    "mParticle": "support@mparticle.com"
  },
  "source": {
    "git": "https://github.com/mparticle-integrations/mparticle-apple-integration-urbanairship-19.git",
    "tag": "v9.2.1"
  },
  "platforms": {
    "ios": "15.6"
  },
  "ios": {
    "source_files": "Sources/mParticle-UrbanAirship/**/*.{h,m}",
    "resource_bundles": {
      "mParticle-UrbanAirship-19-Privacy": [
        "Sources/mParticle-UrbanAirship/PrivacyInfo.xcprivacy"
      ]
    },
    "pod_target_xcconfig": {
      "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) AIRSHIP_COCOAPODS=1"
    },
    "dependencies": {
      "mParticle-Apple-SDK": [
        "~> 9.0"
      ],
      "Airship/ObjectiveC": [
        "~> 19.1"
      ]
    }
  }
}
