{
  "name": "DooPushSDK",
  "version": "1.3.0",
  "summary": "DooPush iOS SDK - 简单易用的推送通知解决方案",
  "description": "DooPush iOS SDK 提供简单易用的推送通知解决方案，支持：\n\n• iOS APNs 推送通知\n• 设备自动注册和管理\n• 灵活的服务器配置（支持本地开发环境）\n• Swift 和 Objective-C 双语言支持\n• 完整的错误处理和日志系统\n• 本地数据存储和管理\n\n适用于需要推送通知功能的iOS应用。",
  "homepage": "https://github.com/doopush/doopush-ios-sdk",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "DooPush Team": "support@doopush.com"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": "5.9",
  "source": {
    "git": "https://github.com/doopush/doopush-ios-sdk.git",
    "tag": "v1.3.0"
  },
  "source_files": "Sources/DooPushSDK/**/*.swift",
  "frameworks": [
    "Foundation",
    "UIKit",
    "UserNotifications"
  ],
  "requires_arc": true,
  "pod_target_xcconfig": {
    "SWIFT_VERSION": "5.9",
    "IPHONEOS_DEPLOYMENT_TARGET": "13.0"
  },
  "testspecs": [
    {
      "name": "Tests",
      "test_type": "unit",
      "source_files": "Tests/**/*.swift",
      "frameworks": "XCTest",
      "requires_app_host": true
    }
  ],
  "swift_version": "5.9"
}
