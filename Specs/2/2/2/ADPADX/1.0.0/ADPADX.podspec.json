{
  "name": "ADPADX",
  "version": "1.0.0",
  "summary": "AdsPlus self-owned ADX iOS SDK.",
  "description": "ADPADX provides AdsPlus self-owned splash ad loading, display, tracking and logging.",
  "homepage": "https://github.com/adsplusteam/adsplus-ios-adx",
  "license": {
    "type": "Proprietary",
    "text": "Copyright AdsPlus. All rights reserved."
  },
  "authors": {
    "AdsPlus": "adsplus@gmail.com"
  },
  "source": {
    "git": "https://github.com/adsplusteam/adsplus-ios-adx.git",
    "tag": "1.0.0"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": "5.0",
  "static_framework": true,
  "vendored_frameworks": "ADPADX/ADPADX.xcframework",
  "resources": "ADPADX/ADPADX.bundle",
  "dependencies": {
    "ADPFoundation": [
      "1.0.0"
    ],
    "AliyunLogProducer": [
      "3.1.16"
    ]
  },
  "frameworks": [
    "UIKit",
    "Foundation",
    "Security",
    "ImageIO",
    "MobileCoreServices",
    "CoreGraphics",
    "QuartzCore",
    "CryptoKit"
  ],
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64",
    "LIBRARY_SEARCH_PATHS": "$(inherited) $(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "x86_64",
    "LIBRARY_SEARCH_PATHS": "$(inherited) $(TOOLCHAIN_DIR)/usr/lib/swift/$(PLATFORM_NAME)",
    "ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES": "YES"
  },
  "swift_version": "5.0"
}
