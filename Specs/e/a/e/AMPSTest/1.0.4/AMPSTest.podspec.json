{
  "name": "AMPSTest",
  "version": "1.0.4",
  "summary": "AMPS 聚合 SDK 调试测试工具（二进制）",
  "description": "测试联调专用。依赖 AMPSAdSDK ~> 5.1.2.3。\n渠道图标通过网络 URL 异步加载，无需本地图片资源包。\nAMPSTest 须直接依赖在最终 App Target（非仅静态库 Target）。宿主须 Debug 编译。",
  "homepage": "https://gitee.com/adscope_admin/AMPSTest",
  "license": {
    "type": "Proprietary"
  },
  "authors": {
    "AdScope": "dev@adscope.com.cn"
  },
  "platforms": {
    "ios": "11.0"
  },
  "requires_arc": true,
  "source": {
    "git": "https://gitee.com/adscope_admin/AMPSTest.git",
    "tag": "1.0.4"
  },
  "static_framework": true,
  "vendored_frameworks": "AMPSTest.xcframework",
  "dependencies": {
    "AMPSAdSDK": [
      "~> 5.1.2.3"
    ]
  },
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "$(inherited) -ObjC"
  }
}
