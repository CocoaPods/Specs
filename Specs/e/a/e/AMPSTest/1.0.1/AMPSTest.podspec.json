{
  "name": "AMPSTest",
  "version": "1.0.1",
  "summary": "AMPS 聚合 SDK 调试测试工具（二进制）",
  "description": "测试联调专用。依赖 AMPSAdSDK ~> 5.1.2.3。\n渠道图标在 AMPSTest.bundle，由 s.resources 打入宿主 App.app/AMPSTest.bundle。\nAMPSTest 须直接依赖在最终 App Target（非仅静态库 Target）。宿主须 Debug 编译。",
  "homepage": "https://gitee.com/adscope_admin/AMPSTest",
  "license": {
    "type": "Proprietary"
  },
  "authors": {
    "AdScope": "dev@adscope.com.cn"
  },
  "platforms": {
    "ios": "11.0"
  },
  "requires_arc": true,
  "source": {
    "git": "https://gitee.com/adscope_admin/AMPSTest.git",
    "tag": "1.0.1"
  },
  "static_framework": true,
  "vendored_frameworks": "AMPSTest.xcframework",
  "resources": [
    "AMPSTest.bundle"
  ],
  "dependencies": {
    "AMPSAdSDK": [
      "~> 5.1.2.3"
    ]
  },
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "$(inherited) -ObjC"
  }
}
