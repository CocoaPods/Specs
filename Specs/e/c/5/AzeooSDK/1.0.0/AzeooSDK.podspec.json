{
  "name": "AzeooSDK",
  "version": "1.0.0",
  "summary": "AzeooSDK - iOS SDK for nutrition and health functionality",
  "description": "AzeooSDK is a Swift Package Manager library that provides a native iOS wrapper \naround a Flutter-based SDK. The SDK offers nutrition and health-related \nfunctionality through a hybrid Flutter/iOS architecture.",
  "homepage": "https://bitbucket.org/azeoo/azeoo_sdk_spm",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Azeoo": "puvistyne.rajasegar@azeoo.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://bitbucket.org/azeoo/azeoo_sdk_spm.git",
    "tag": "1.0.0"
  },
  "source_files": "Sources/AzeooSDK/Exports.swift",
  "vendored_frameworks": [
    "Sources/AzeooSDK/Frameworks/azeoo_core.xcframework",
    "Sources/AzeooSDK/Frameworks/Flutter.xcframework",
    "Sources/AzeooSDK/Frameworks/App.xcframework",
    "Sources/AzeooSDK/Frameworks/FlutterPluginRegistrant.xcframework",
    "Sources/AzeooSDK/Frameworks/objective_c.xcframework",
    "Sources/AzeooSDK/Frameworks/camera_avfoundation.xcframework",
    "Sources/AzeooSDK/Frameworks/connectivity_plus.xcframework",
    "Sources/AzeooSDK/Frameworks/mobile_scanner.xcframework",
    "Sources/AzeooSDK/Frameworks/permission_handler_apple.xcframework",
    "Sources/AzeooSDK/Frameworks/shared_preferences_foundation.xcframework",
    "Sources/AzeooSDK/Frameworks/url_launcher_ios.xcframework",
    "Sources/AzeooSDK/Frameworks/sqflite_darwin.xcframework",
    "Sources/AzeooSDK/Frameworks/app_links.xcframework",
    "Sources/AzeooSDK/Frameworks/image_picker_ios.xcframework",
    "Sources/AzeooSDK/Frameworks/device_info_plus.xcframework",
    "Sources/AzeooSDK/Frameworks/flutter_localization.xcframework",
    "Sources/AzeooSDK/Frameworks/vibration.xcframework",
    "Sources/AzeooSDK/Frameworks/flutter_secure_storage_darwin.xcframework",
    "Sources/AzeooSDK/Frameworks/webview_flutter_wkwebview.xcframework"
  ],
  "frameworks": [
    "Foundation",
    "UIKit",
    "SwiftUI"
  ],
  "pod_target_xcconfig": {
    "SWIFT_VERSION": "5.0",
    "OTHER_LDFLAGS": "-weak_framework SwiftUI"
  },
  "weak_frameworks": "SwiftUI",
  "swift_version": "5.0"
}
