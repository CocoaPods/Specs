{
  "name": "BmobSwiftSDK",
  "version": "1.0.2",
  "summary": "Bmob Swift SDK — 纯 Swift 实现的 Bmob 后端云 SDK，支持 iOS/macOS 双平台",
  "description": "全新 Bmob Swift SDK，采用 async/await 并发模型，支持 SPM 和 CocoaPods 双通道集成。\n提供用户管理、数据表 CRUD、文件上传下载、云函数调用、ACL 角色管理、实时数据监听等功能。",
  "homepage": "https://www.bmobapp.com",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Bmob": "support@bmob.cn"
  },
  "source": {
    "git": "https://github.com/bmob/BmobSwiftSDK.git",
    "tag": "v1.0.2"
  },
  "swift_versions": [
    "5.9"
  ],
  "platforms": {
    "ios": "15.0",
    "osx": "12.0"
  },
  "default_subspecs": "All",
  "subspecs": [
    {
      "name": "All",
      "dependencies": {
        "BmobSwiftSDK/Core": [

        ],
        "BmobSwiftSDK/Data": [

        ],
        "BmobSwiftSDK/User": [

        ],
        "BmobSwiftSDK/File": [

        ],
        "BmobSwiftSDK/Cloud": [

        ]
      }
    },
    {
      "name": "Core",
      "source_files": "Sources/BmobCore/**/*.swift",
      "frameworks": [
        "Foundation",
        "Security"
      ]
    },
    {
      "name": "Data",
      "source_files": "Sources/BmobData/**/*.swift",
      "dependencies": {
        "BmobSwiftSDK/Core": [

        ]
      }
    },
    {
      "name": "User",
      "source_files": "Sources/BmobUser/**/*.swift",
      "dependencies": {
        "BmobSwiftSDK/Core": [

        ],
        "BmobSwiftSDK/Data": [

        ]
      }
    },
    {
      "name": "File",
      "source_files": "Sources/BmobFile/**/*.swift",
      "dependencies": {
        "BmobSwiftSDK/Core": [

        ],
        "BmobSwiftSDK/Data": [

        ]
      }
    },
    {
      "name": "Cloud",
      "source_files": "Sources/BmobCloud/**/*.swift",
      "dependencies": {
        "BmobSwiftSDK/Core": [

        ]
      }
    }
  ],
  "swift_version": "5.9"
}
