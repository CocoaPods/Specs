    "Framework/Products/Products/**/*.bundle",
    "Framework/Products/Products/**/*.lproj",
    "Framework/Products/Products/**/*.xcprivacy"
  ],
  "frameworks": [
    "Accelerate",
    "AdSupport",
    "AVFoundation",
    "AudioToolbox",
    "CFNetwork",
    "CoreFoundation",
    "CoreGraphics",
    "CoreImage",
    "CoreLocation",
    "CoreMedia",
    "CoreMotion",
    "CoreTelephony",
    "CoreVideo",
    "Foundation",
    "ImageIO",
    "LocalAuthentication",
    "MobileCoreServices",
    "Photos",
    "QuartzCore",
    "ReplayKit",
    "Security",
    "SystemConfiguration",
    "UIKit",
    "WebKit"
  ],
  "libraries": [
    "c++",
    "c++abi",
    "resolv",
    "z"
  ],
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  }
}
