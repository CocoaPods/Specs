{
  "name": "UTSAliFaceDetect",
  "version": "1.0.4",
  "summary": "UTSAliFaceDetect binary frameworks",
  "description": "iOS binary frameworks and resources required by UTSAliFaceDetect.",
  "homepage": "https://github.com/52yaoer/UTSAliFaceDetect",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "176142998": "176142998@qq.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "source": {
    "http": "https://github.com/52yaoer/UTSAliFaceDetect/archive/refs/tags/1.0.4.tar.gz"
  },
  "vendored_frameworks": [
    "Framework/Products/Products/*.framework"
  ],
