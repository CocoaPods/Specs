{
  "name": "HXToBidAdapterNew",
  "version": "1.0.0",
  "summary": "HXSDK adapter for ToBid 5.x custom mediation",
  "homepage": "https://gitee.com/octmon/hxwind-adapter-new-ios.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "OctMon": "octmon@qq.com"
  },
  "source": {
    "git": "https://gitee.com/octmon/hxwind-adapter-new-ios.git",
    "tag": "1.0.0"
  },
  "platforms": {
    "ios": "11.0"
  },
  "static_framework": true,
  "ios": {
    "source_files": "HXToBidAdapter/Classes/**/*.{h,m}",
    "public_header_files": "HXToBidAdapter/Classes/**/*.h"
  },
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64",
    "OTHER_LDFLAGS": "$(inherited) -ObjC"
  },
  "dependencies": {
    "HXSDK": [
      "~> 5.1.5"
    ],
    "ToBid-iOS-RC": [
      ">= 5.5.2"
    ]
  }
}
