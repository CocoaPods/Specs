{
  "name": "agent-client-toolkit-swift",
  "module_name": "AgoraAgentClientToolkit",
  "version": "1.0.0",
  "summary": "Client-side toolkit for Agora Conversational AI on iOS.",
  "description": "A lightweight iOS toolkit that adds Conversational AI messaging,\ntranscript, state, interrupt, and metrics handling on top of\nhost-managed Agora RTC and RTM engine instances.",
  "homepage": "https://www.agora.io",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "Agora": "developer@agora.io"
  },
  "source": {
    "http": "https://download.agora.io/sdk/release/agent-client-toolkit-swift-1.0.0.zip"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.0",
  "static_framework": true,
  "vendored_frameworks": "AgoraAgentClientToolkit.xcframework",
  "weak_frameworks": "AgoraAgentClientToolkit",
  "requires_arc": true,
  "xcconfig": {
    "ENABLE_BITCODE": "NO"
  },
  "dependencies": {
    "AgoraRtcEngine_iOS": [
      ">= 4.5.1"
    ],
    "AgoraRtm/RtmKit": [
      ">= 2.2.3"
    ]
  },
  "swift_version": "5.0"
}
