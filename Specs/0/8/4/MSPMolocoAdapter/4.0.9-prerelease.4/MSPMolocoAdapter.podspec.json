{
  "name": "MSPMolocoAdapter",
  "summary": "an adapter for Moloco SDK",
  "description": "an adapter for Moloco SDK",
  "homepage": "https://github.com/ParticleMedia/msp-ios-sdk-public",
  "license": "Copyright",
  "authors": {
    "Mingming Luo": "mingming.luo@newsbreak.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "static_framework": true,
  "pod_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(inherited) $(PODS_CONFIGURATION_BUILD_DIR)",
    "VALID_ARCHS": "x86_64 armv7 arm64",
    "DEFINES_MODULE": "YES"
  },
  "user_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(inherited) $(PODS_CONFIGURATION_BUILD_DIR)",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "dependencies": {
    "MolocoSDKiOS": [
      "~> 4.2"
    ],
    "MSPSharedLibraries": [
      "4.0.9-prerelease.4"
    ],
    "MSPiOSCore": [
      "4.0.9-prerelease.4"
    ]
  },
  "version": "4.0.9-prerelease.4",
  "source": {
    "http": "https://github.com/ParticleMedia/msp-ios-sdk-public/releases/download/4.0.9-prerelease.4/MSPMolocoAdapter-4.0.9-prerelease.4.zip",
    "type": "zip",
    "sha256": "4ed5657321e9c089923fc7123668d21ef9761a7380273b0bc5148eb7224f489b"
  },
  "vendored_frameworks": "Binary/MSPMolocoAdapter.xcframework",
  "swift_version": "5.0"
}
