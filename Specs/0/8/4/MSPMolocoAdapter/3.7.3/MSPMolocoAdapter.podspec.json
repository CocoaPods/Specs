{
  "name": "MSPMolocoAdapter",
  "summary": "an adapter for Moloco SDK",
  "description": "an adapter for Moloco SDK",
  "homepage": "https://github.com/ParticleMedia/msp-ios-sdk-public",
  "license": "Copyright",
  "authors": {
    "Mingming Luo": "mingming.luo@newsbreak.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "static_framework": true,
  "pod_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(inherited) $(PODS_CONFIGURATION_BUILD_DIR)",
    "VALID_ARCHS": "x86_64 armv7 arm64",
    "DEFINES_MODULE": "YES"
  },
  "user_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(inherited) $(PODS_CONFIGURATION_BUILD_DIR)",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "dependencies": {
    "MolocoSDKiOS": [
      "~> 4.2"
    ],
    "MSPSharedLibraries": [
      "3.7.3"
    ],
    "MSPiOSCore": [
      "3.7.3"
    ]
  },
  "version": "3.7.3",
  "source": {
    "http": "https://github.com/ParticleMedia/msp-ios-sdk-public/releases/download/3.7.3/MSPMolocoAdapter-3.7.3.zip",
    "type": "zip",
    "sha256": "e78be1fd54dd1d14b790466a5f8c7d2ba25d1a34d4d1d32d428c0d8fb4c8373f"
  },
  "vendored_frameworks": "Binary/MSPMolocoAdapter.xcframework",
  "swift_version": "5.0"
}
