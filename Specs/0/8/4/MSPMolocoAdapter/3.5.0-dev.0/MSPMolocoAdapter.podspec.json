{
  "name": "MSPMolocoAdapter",
  "summary": "an adapter for Moloco SDK",
  "description": "an adapter for Moloco SDK",
  "homepage": "https://github.com/ParticleMedia/msp-ios-sdk-public",
  "license": "Copyright",
  "authors": {
    "Mingming Luo": "mingming.luo@newsbreak.com"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.0",
  "requires_arc": true,
  "static_framework": true,
  "pod_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(inherited) $(PODS_CONFIGURATION_BUILD_DIR)",
    "VALID_ARCHS": "x86_64 armv7 arm64",
    "DEFINES_MODULE": "YES"
  },
  "user_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(inherited) $(PODS_CONFIGURATION_BUILD_DIR)",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "arm64"
  },
  "dependencies": {
    "MolocoSDKiOS": [
      "~> 4.2"
    ],
    "MSPSharedLibraries": [
      "3.5.0-dev.0"
    ],
    "MSPiOSCore": [
      "3.5.0-dev.0"
    ]
  },
  "version": "3.5.0-dev.0",
  "source": {
    "http": "https://github.com/ParticleMedia/msp-ios-sdk-public/releases/download/3.5.0-dev.0/MSPMolocoAdapter-3.5.0-dev.0.zip",
    "type": "zip",
    "sha256": "6366a60ea3af7209e00a2abbfa737ee357afd1525614142cdd39c526a6c94f93"
  },
  "vendored_frameworks": "Binary/MSPMolocoAdapter.xcframework",
  "swift_version": "5.0"
}
