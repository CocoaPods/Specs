{
  "name": "VietmapSpeedAlertSDK",
  "version": "0.0.2",
  "summary": "Vietmap Speed Alert SDK – GPS tracking and real-time speed alert for iOS.",
  "description": "VietmapSpeedAlertSDK provides GPS tracking and speed alert functionality with a\nshared C++ core. Features include real-time speed limit detection, camera alerts,\ntoll booth detection, route progress tracking, and TTS announcements.",
  "homepage": "https://github.com/vietmap-company/vietmap-speed-alert-sdk",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Vietmap": "support@vietmap.vn"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/vietmap-company/vietmap-speed-alert-sdk.git",
    "tag": "ios-0.0.2"
  },
  "vendored_frameworks": "VietmapSpeedAlertSDK.xcframework",
  "frameworks": [
    "Foundation",
    "CoreLocation",
    "UIKit"
  ],
  "requires_arc": true,
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++17",
    "CLANG_CXX_LIBRARY": "libc++",
    "DEFINES_MODULE": "YES",
    "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
  },
  "user_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++17",
    "CLANG_CXX_LIBRARY": "libc++"
  },
  "swift_version": "5.0"
}
