    "Harbeth": [
      "Sources/**/**/*.metal"
    ]
  },
  "weak_frameworks": [
    "ImageIO",
    "MetalKit",
    "AVFoundation",
    "MetalPerformanceShaders",
    "CoreImage"
  ],
  "swift_version": "5.0"
