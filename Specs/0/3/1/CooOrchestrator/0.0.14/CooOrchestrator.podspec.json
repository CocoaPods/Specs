{
  "name": "CooOrchestrator",
  "version": "0.0.14",
  "summary": "一个用于模块化管理应用生命周期与插件编排的调度框架。",
  "description": "CooOrchestrator是一个用于模块化管理应用生命周期与插件编排的调度框架，\n提供统一的插件协议、时机与优先级、生命周期与自动注册（Manifest），\n支持多线程安全调度。",
  "homepage": "https://github.com/CircularCyanStone/Orchestrator",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "coocy": "coo@example.com"
  },
  "source": {
    "git": "https://github.com/CircularCyanStone/Orchestrator.git",
    "tag": "0.0.14"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": [
    "5.0"
  ],
  "source_files": "Sources/CooOrchestrator/**/*.{h,swift}",
  "exclude_files": [
    "Sources/CooOrchestrator/macros/**/*",
    "Sources/CooOrchestrator/pluginLoaders/OhSwiftSectionLoader.swift"
  ],
  "public_header_files": "Sources/CooOrchestrator/**/*.h",
  "pod_target_xcconfig": {
    "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "$(inherited) COCOAPODS"
  },
  "swift_version": "5.0"
}
