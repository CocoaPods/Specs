{
  "name": "ffmpeg-mobile-min",
  "version": "7.1.5",
  "summary": "FFmpegKit iOS xcframeworks (min package)",
  "description": "Prebuilt FFmpeg/FFmpegKit xcframeworks for iOS. Community rebuild of arthenica/ffmpeg-kit, built up to FFmpeg 6 under LGPL v3.0.",
  "homepage": "https://github.com/maitrungduc1410/ffmpeg-kit",
  "license": {
    "type": "LGPL-3.0",
    "file": "LICENSE"
  },
  "authors": {
    "Duc Trung Mai": "maitrungduc1410@gmail.com"
  },
  "platforms": {
    "ios": "12.1"
  },
  "source": {
    "http": "https://github.com/maitrungduc1410/ffmpeg-kit/releases/download/ios-7.1.5/ffmpeg-mobile-min.zip"
  },
  "frameworks": [
    "AudioToolbox",
    "AVFoundation",
    "CoreMedia",
    "VideoToolbox"
  ],
  "libraries": [
    "z",
    "bz2",
    "iconv"
  ],
  "vendored_frameworks": [
    "libswscale.xcframework",
    "libswresample.xcframework",
    "libavutil.xcframework",
    "libavformat.xcframework",
    "libavfilter.xcframework",
    "libavdevice.xcframework",
    "libavcodec.xcframework",
    "ffmpegkit.xcframework"
  ]
