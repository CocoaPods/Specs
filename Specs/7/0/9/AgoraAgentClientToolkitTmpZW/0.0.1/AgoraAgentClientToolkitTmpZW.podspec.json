  "license": {
    "type": "MIT"
  },
  "authors": {
    "Agora": "developer@agora.io"
  },
  "source": {
    "git": "https://github.com/alienzh/Conversational-AI-Demo.git",
    "tag": "0.0.1"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.0",
  "static_framework": true,
  "requires_arc": true,
  "xcconfig": {
    "ENABLE_BITCODE": "NO"
  },
  "source_files": [
    "iOS/AgoraAgentClientToolkit/AgoraAgentClientToolkit/Classes/**/*.swift"
  ],
  "dependencies": {
    "AgoraRtcEngine_iOS": [
      ">= 4.5.1",
      "< 5.0"
