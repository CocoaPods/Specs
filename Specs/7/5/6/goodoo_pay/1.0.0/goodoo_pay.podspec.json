{
  "name": "goodoo_pay",
  "version": "1.0.0",
  "summary": "GoodooPay Flutter SDK for payment integration",
  "description": "Native iOS bridge for launching the embedded GoodooPay Flutter payment flow\nfrom UIKit applications and receiving structured payment results.",
  "homepage": "https://github.com/GoodooLLC/goodoopay-ios-sdk",
  "license": {
    "type": "MIT"
  },
  "authors": {
    "GoodooPay": "support@goodoo.kg"
  },
  "source": {
    "git": "https://github.com/GoodooLLC/goodoopay-ios-sdk.git",
    "tag": "v1.0.0"
  },
  "source_files": "{Classes,ios/Classes}/**/*",
  "vendored_frameworks": "{Frameworks,ios/Frameworks}/**/*.xcframework",
  "preserve_paths": "{Frameworks,ios/Frameworks}/**/*.xcframework",
  "platforms": {
    "ios": "13.0"
  },
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "swift_versions": "5.0",
  "swift_version": "5.0"
}
