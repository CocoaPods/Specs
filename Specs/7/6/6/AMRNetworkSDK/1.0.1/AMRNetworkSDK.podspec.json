{
  "name": "AMRNetworkSDK",
  "version": "1.0.1",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "homepage": "http://www.admost.com/",
  "authors": {
    "Admost Mediation Limited": "amr@admost.com"
  },
  "summary": "Automatic HTTP network traffic monitoring add-on for AMRSDK.",
  "description": "AMRNetworkSDK auto-captures HTTP(S) traffic in the host app via NSURLProtocol\nand NSURLSession swizzling, then forwards each request to AMRSDK for event\nreporting. Drop-in addition to AMRSDK — no integration code required.",
  "source": {
    "git": "https://github.com/admost/AMR-IOS-NETWORK-SDK.git",
    "tag": "1.0.1"
  },
  "documentation_url": "https://admost.github.io/amrios/",
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": [
    "5"
  ],
  "vendored_frameworks": "AMRNetworkSDK/Libs/AMRNetworkSDK.xcframework",
  "pod_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC",
    "VALID_ARCHS": "arm64 x86_64",
    "VALID_ARCHS[sdk=iphoneos*]": "arm64",
    "VALID_ARCHS[sdk=iphonesimulator*]": "x86_64 arm64"
  },
  "dependencies": {
    "AMRSDK": [
      "~> 1.5.92"
    ]
  },
  "swift_version": "5"
}
