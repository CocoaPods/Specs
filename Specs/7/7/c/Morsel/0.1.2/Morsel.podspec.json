{
  "name": "Morsel",
  "version": "0.1.2",
  "summary": "A tiny in-app snackbar / toast for UIKit and SwiftUI.",
  "description": "Morsel shows a short, auto-dismissing bar (a snackbar / toast) at the bottom\nof your app's screen. No permissions or notifications — pure in-app UI, with\na queue and delay-based scheduling, for both UIKit and SwiftUI.",
  "homepage": "https://github.com/zetro-nayatel/Morsel",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "zetro-nayatel": "zetro.work@gmail.com"
  },
  "source": {
    "git": "https://github.com/zetro-nayatel/Morsel.git",
    "tag": "0.1.2"
  },
  "swift_versions": "6.0",
  "platforms": {
    "ios": "15.0"
  },
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Core",
      "source_files": "Sources/MorselCore/**/*.swift",
      "frameworks": "Foundation"
    },
    {
      "name": "UIKit",
      "source_files": "Sources/MorselUIKit/**/*.swift",
      "frameworks": "UIKit",
      "dependencies": {
        "Morsel/Core": [

        ]
      }
    },
    {
      "name": "SwiftUI",
      "source_files": "Sources/MorselSwiftUI/**/*.swift",
      "frameworks": "SwiftUI",
      "dependencies": {
        "Morsel/Core": [

        ]
      }
    }
  ],
  "swift_version": "6.0"
}
