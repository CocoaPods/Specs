{
  "name": "SmartPlayer",
  "version": "0.0.4",
  "summary": "基础版本",
  "description": "集成大牛SDK，模块化",
  "homepage": "https://daniusdk.com/",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "SmallPeak": "byron3241@qq.com"
  },
  "source": {
    "git": "https://gitee.com/librarybyself/smartplayer.git",
    "tag": "0.0.4"
  },
  "platforms": {
    "ios": "12.0"
  },
  "static_framework": true,
  "swift_versions": "5.0",
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "OTHER_SWIFT_FLAGS": "-Xcc -fmodule-map-file=${PODS_ROOT}/SmartPlayer/SmartPlayer.modulemap"
  },
  "public_header_files": "SmartPlayer/Classes/**/*.h",
  "source_files": "SmartPlayer/Classes/**/*",
  "vendored_libraries": "SmartPlayer/Classes/*.a",
  "frameworks": "VideoToolbox",
  "libraries": [
    "bz2",
    "c++",
    "iconv"
  ],
  "swift_version": "5.0"
}
