{
  "name": "WeDoBooks",
  "version": "1.3.1",
  "summary": "WeDoBooks iOS SDK with bundled Firebase provider integration.",
  "description": "WeDoBooks iOS SDK distribution for CocoaPods. This pod ships WeDoBooksSDK,\nColibrioReader, WDBFirebaseInterfaces, and FirebaseProvider sources in a\nsingle bundle to support integrations that cannot use Swift Package Manager.",
  "homepage": "https://github.com/wedobooks/wedobooks-sdk-ios-spm",
  "license": {
    "type": "Commercial",
    "text": "Copyright (c) WeDoBooks. All rights reserved."
  },
  "authors": {
    "WeDoBooks": "sdk@wedobooks.io"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": [
    "6.0"
  ],
  "static_framework": true,
  "source": {
    "http": "https://wdb-ios-spm-844218222632.europe-west1.run.app/WeDoBooksPod-v1.3.1.zip",
    "sha256": "ad46be9eef282867b5cec8aa7eb04707df2b552b86446bd0d262196d1735c846"
  },
  "source_files": [
    "Sources/WeDoBooksWrapper/**/*.swift",
    "Sources/FirebaseProvider/**/*.swift"
  ],
  "pod_target_xcconfig": {
    "BUILD_LIBRARY_FOR_DISTRIBUTION": "YES"
  },
  "vendored_frameworks": [
    "Vendor/WeDoBooksSDK.xcframework",
    "Vendor/ColibrioReader.xcframework",
    "Vendor/WDBFirebaseInterfaces.xcframework"
  ],
  "dependencies": {
    "FirebaseCore": [
      ">= 12.9",
      "< 13.0"
    ],
    "FirebaseAnalytics": [
      ">= 12.9",
      "< 13.0"
    ],
    "FirebaseAuth": [
      ">= 12.9",
      "< 13.0"
    ],
    "FirebaseFirestore": [
      ">= 12.9",
      "< 13.0"
    ],
    "FirebaseFunctions": [
      ">= 12.9",
      "< 13.0"
    ],
    "FirebaseRemoteConfig": [
      ">= 12.9",
      "< 13.0"
    ]
  },
  "swift_version": "6.0"
}
