  "homepage": "https://github.com/apple/swift-log",
  "license": {
    "type": "Apache 2.0",
    "file": "LICENSE.txt"
  },
  "source": {
    "git": "https://github.com/apple/swift-log.git",
    "tag": "1.8.0"
  },
  "authors": {
    "Kris Kline": "kris.kline@oracle.com",
    "Vladimir Kukushkin": "kukushechkin@mac.com"
  },
  "swift_versions": "6.0",
  "platforms": {
    "ios": "12.0",
    "osx": "11.0",
    "tvos": "12.0",
    "visionos": "1.0",
    "watchos": "8.0"
  },
  "source_files": "Sources/InMemoryLogging/**/*.swift",
  "dependencies": {
    "SwiftlyLogging": [
      "1.8.0"
