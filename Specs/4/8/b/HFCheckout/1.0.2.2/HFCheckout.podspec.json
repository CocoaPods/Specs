{
  "name": "HFCheckout",
  "version": "1.0.2.2",
  "summary": "HFCheckout",
  "description": "HFCheckout SDK",
  "homepage": "https://github.com/huifurepo/hfpx-checkout-ios",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "zhangtibin": "tibin.zhang@huifu.com"
  },
  "source": {
    "git": "https://github.com/huifurepo/hfpx-checkout-ios.git",
    "tag": "1.0.2.2"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "frameworks": [
    "UIKit",
    "Foundation",
    "SystemConfiguration",
    "CoreTelephony",
    "QuartzCore",
    "CoreText",
    "CoreGraphics",
    "CoreMotion",
    "Security",
    "WebKit",
    "Network"
  ],
  "libraries": [
    "c++",
    "z",
    "sqlite3"
  ],
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Core",
      "vendored_frameworks": [
        "HFCheckout/HFCheckout.xcframework",
        "HFCheckout/Frameworks/GMObjC/GMObjC.framework"
      ],
      "resource_bundles": {
        "HFCheckout": [
          "HFCheckout/Assets/**/*"
        ]
      }
    },
    {
      "name": "WechatPaySDK",
      "dependencies": {
        "HFCheckout/Core": [

        ],
        "WechatOpenSDK-XCFramework": [

        ]
      },
      "pod_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      }
    },
    {
      "name": "AlipaySDK",
      "dependencies": {
        "HFCheckout/Core": [

        ],
        "AlipaySDK-iOS": [

        ]
      },
      "pod_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      }
    },
    {
      "name": "UnionPaySDK",
      "dependencies": {
        "HFCheckout/Core": [

        ]
      },
      "vendored_frameworks": "HFCheckout/Frameworks/UPPaymentControl/UPPaymentControlMini.framework",
      "vendored_libraries": "HFCheckout/Frameworks/UMSPosPayOnly/libUMSPosPayOnly.a",
      "pod_target_xcconfig": {
        "OTHER_LDFLAGS": "-ObjC"
      }
    },
    {
      "name": "All",
      "dependencies": {
        "HFCheckout/WechatPaySDK": [

        ],
        "HFCheckout/AlipaySDK": [

        ],
        "HFCheckout/UnionPaySDK": [

        ]
      }
    }
  ]
}
