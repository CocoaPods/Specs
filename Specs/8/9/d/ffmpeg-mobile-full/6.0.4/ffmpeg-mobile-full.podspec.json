{
  "name": "ffmpeg-mobile-full",
  "version": "6.0.4",
  "summary": "FFmpegKit iOS xcframeworks (full package)",
  "description": "Prebuilt FFmpeg/FFmpegKit xcframeworks for iOS. Community rebuild of arthenica/ffmpeg-kit, built up to FFmpeg 6 under LGPL v3.0.",
  "homepage": "https://github.com/maitrungduc1410/ffmpeg-kit",
  "license": {
    "type": "LGPL-3.0",
    "file": "LICENSE"
  },
  "authors": {
    "Duc Trung Mai": "maitrungduc1410@gmail.com"
  },
  "platforms": {
    "ios": "12.1"
  },
  "source": {
    "http": "https://github.com/maitrungduc1410/ffmpeg-kit/releases/download/ios-6.0.4/ffmpeg-mobile-full.zip"
  },
  "frameworks": [
    "AudioToolbox",
    "AVFoundation",
    "CoreMedia",
    "VideoToolbox"
  ],
  "libraries": [
    "z",
    "bz2",
    "iconv"
