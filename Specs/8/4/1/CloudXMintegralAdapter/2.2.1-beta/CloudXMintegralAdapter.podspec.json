{
  "name": "CloudXMintegralAdapter",
  "version": "2.2.1-beta",
  "summary": "CloudX Mintegral Adapter - Static Framework",
  "description": "Mintegral adapter for CloudX iOS SDK - binary distribution",
  "homepage": "https://github.com/cloudx-io/cloudx-ios",
  "license": {
    "type": "Business Source License 1.1"
  },
  "authors": {
    "CloudX": "support@cloudx.io"
  },
  "source": {
    "git": "https://github.com/cloudx-io/cloudx-ios.git",
    "tag": "v2.2.1-beta-mintegral"
  },
  "platforms": {
    "ios": "13.0"
  },
  "vendored_frameworks": "adapter-mintegral/CloudXMintegralAdapter.xcframework",
  "dependencies": {
    "CloudXCore": [
      "2.2.1-beta"
    ],
    "MintegralAdSDK": [
      "~> 8.0"
    ],
    "MintegralAdSDK/BidBannerAd": [
      "~> 8.0"
    ],
    "MintegralAdSDK/BidNewInterstitialAd": [
      "~> 8.0"
    ],
    "MintegralAdSDK/BidRewardVideoAd": [
      "~> 8.0"
    ]
  },
  "frameworks": [
    "Foundation",
    "UIKit",
    "AdSupport",
    "CoreGraphics",
    "CoreTelephony",
    "SystemConfiguration",
    "AVFoundation",
    "CoreMedia",
    "QuartzCore",
    "StoreKit",
    "WebKit"
  ],
  "weak_frameworks": [
    "AppTrackingTransparency"
  ],
  "requires_arc": true,
  "static_framework": true,
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386"
  },
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "swift_versions": [
    "5.0",
    "5.1",
    "5.2",
    "5.3",
    "5.4",
    "5.5",
    "5.6",
    "5.7",
    "5.8",
    "5.9",
    "6.0",
    "6.1",
    "6.2"
  ],
  "swift_version": "6.2"
}
