{
  "name": "BYRWebRTC",
  "version": "0.1.1",
  "summary": "自定义WebRTC",
  "description": "自定义WebRTC，可识别HEDV的流",
  "homepage": "https://gitee.com/librarybyself/BYRWebRTC",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "HandsomePeak": "1071210272@qq.com"
  },
  "source": {
    "git": "https://gitee.com/librarybyself/BYRWebRTC.git",
    "tag": "0.1.1"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": "5.0",
  "static_framework": true,
  "source_files": "BYRWebRTC/Classes/**/*.{swift,h,m}",
  "vendored_frameworks": "BYRWebRTC/Classes/WebRTC.xcframework",
  "frameworks": [
    "AVFoundation",
    "AudioToolbox",
    "CoreAudio",
    "CoreGraphics",
    "CoreMedia",
    "CoreVideo",
    "GLKit",
    "VideoToolbox",
    "Network",
    "Security"
  ],
  "libraries": [
    "c++",
    "resolv"
  ],
  "pod_target_xcconfig": {
    "SWIFT_INCLUDE_PATHS": "$(PODS_TARGET_SRCROOT)/BYRWebRTC/Classes/**",
    "HEADER_SEARCH_PATHS": "$(PODS_TARGET_SRCROOT)/BYRWebRTC/Classes/**"
  },
  "swift_version": "5.0"
}
