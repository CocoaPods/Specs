{
  "name": "MapZoneSpeedAlertSDK",
  "version": "1.0.0",
  "summary": "MapZone Speed Alert SDK – GPS tracking and real-time speed alert for iOS.",
  "description": "MapZoneSpeedAlertSDK provides GPS tracking and speed alert functionality with a\nshared C++ core. Features include real-time speed limit detection, camera alerts,\ntoll booth detection, route progress tracking, and TTS announcements.",
  "homepage": "https://github.com/mapzonejsc/mapzone-speed-alert-sdk",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "MapZone": "support@mapzone.vn"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/mapzone-global/mapzone_speed_alert_ios.git",
    "tag": "ios-1.0.0"
  },
  "vendored_frameworks": "MapZoneSpeedAlertSDK.xcframework",
  "frameworks": [
    "Foundation",
    "CoreLocation",
    "UIKit"
  ],
  "requires_arc": true,
  "pod_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++17",
    "CLANG_CXX_LIBRARY": "libc++",
    "DEFINES_MODULE": "YES",
    "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
  },
  "user_target_xcconfig": {
    "CLANG_CXX_LANGUAGE_STANDARD": "c++17",
    "CLANG_CXX_LIBRARY": "libc++"
  },
  "swift_version": "5.0"
}
