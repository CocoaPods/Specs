{
  "name": "BrainCloudCpp",
  "version": "6.0.0",
  "summary": "The C++ client library for brainCloud.",
  "homepage": "http://getbraincloud.com/",
  "platforms": {
    "ios": "15.0",
    "osx": "13.0",
    "tvos": "15.0",
    "visionos": "1.0",
    "watchos": "8.0"
  },
  "license": {
    "type": "Apache License, Version 2.0",
    "file": "LICENSE"
  },
  "authors": {
    "brainCloud Team": "support@getbraincloud.com"
  },
  "source": {
    "git": "https://github.com/getbraincloud/braincloud-cpp.git",
    "tag": "6.0.0"
  },
  "header_mappings_dir": "include",
  "preserve_paths": [
    "include/*",
    "include/**/*"
  ],
  "public_header_files": [
    "include/braincloud/*.h",
    "include/braincloud/internal/*.h",
    "include/braincloud/internal/apple/*.h"
  ],
  "source_files": [
    "src/*.{c,cpp}",
    "src/apple/*.{c,m,cpp,mm}",
    "include/braincloud/*.h",
    "include/braincloud/internal/*.h",
    "include/braincloud/internal/apple/*.h"
  ],
  "exclude_files": [
    "src/DefaultSaveDataHelper.cpp",
    "src/DefaultGUID.cpp",
    "src/DefaultFileUploader.cpp",
    "src/DefaultWebSocket.cpp",
    "src/DefaultPinger.cpp",
    "src/DefaultRelayWSSocket.cpp",
    "include/braincloud/internal/DefaultRelayWSSocket.h"
  ],
  "xcconfig": {
    "USER_HEADER_SEARCH_PATHS": "\"${PODS_ROOT}/BrainCloudCpp/include\" \"${PODS_ROOT}/BrainCloudCpp/include/braincloud/internal/apple\""
  },
  "libraries": [
    "c++",
    "z"
  ],
  "osx": {
    "frameworks": "LDAP",
    "dependencies": {
      "SocketRocket": [
        "~> 0.5"
      ]
    }
  },
  "dependencies": {
    "BrainCloudJsonCpp": [
      "~>6.0.0"
    ]
  },
  "ios": {
    "dependencies": {
      "SocketRocket": [
        "~> 0.5"
      ]
    }
  },
  "tvos": {
    "dependencies": {
      "SocketRocket": [
        "~> 0.5"
      ]
    }
  },
  "visionos": {
    "dependencies": {
      "SocketRocket": [
        "~> 0.5"
      ]
    }
  }
}
