{
  "name": "MRTCSDK",
  "version": "2.1.0",
  "summary": "MRTCSDK is a multi-platform real-time communication SDK for iOS.",
  "description": "MRTCSDK provides multi-platform real-time communication capabilities for iOS,\nsupporting audio/video calls, screen sharing, and whiteboard collaboration.\nIt integrates with ERTC, VCS, and optionally DingRTC backends.",
  "homepage": "https://github.com/Ezviz-Open/MRTCSDK-iOS.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "jinlongyu23": "open-team@ezvizlife.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "static_framework": true,
  "weak_frameworks": [
    "SystemConfiguration",
    "Accelerate",
    "AVFoundation",
    "QuartzCore",
    "CoreGraphics",
    "CoreMedia",
    "CoreAudio",
    "CoreVideo",
    "CoreML",
    "OpenGLES",
    "Security",
    "CFNetwork",
    "UIKit",
    "Foundation",
    "ReplayKit",
    "PushKit",
    "CoreTelephony"
  ],
  "source": {
    "git": "https://github.com/Ezviz-Open/MRTCSDK-iOS.git",
    "tag": "2.1.0"
  },
  "requires_arc": true,
  "default_subspecs": "DingRTC",
  "subspecs": [
    {
      "name": "Core",
      "vendored_frameworks": "Core/MRTCSDK.framework",
      "source_files": "Core/MRTCSDK.framework/Headers/*.h",
      "frameworks": [
        "Foundation",
        "UIKit"
      ],
      "dependencies": {
        "ERTCSDK": [

        ],
        "VCSSDK": [

        ],
        "MMKV": [

        ],
        "Protobuf": [

        ],
        "SSZipArchive": [
          ">= 2.4.3"
        ],
        "AFNetworking": [
          ">= 4.0.0"
        ]
      },
      "pod_target_xcconfig": {
        "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) VCS_USE_PROTOBUF_BEAUTY_IMPORTS=1 MRTC_DINGRTC_ENABLED=0"
      },
      "user_target_xcconfig": {
        "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) VCS_USE_PROTOBUF_BEAUTY_IMPORTS=1 MRTC_DINGRTC_ENABLED=0"
      }
    },
    {
      "name": "DingRTC",
      "vendored_frameworks": "Full/MRTCSDK.framework",
      "source_files": "Full/MRTCSDK.framework/Headers/*.h",
      "frameworks": [
        "Foundation",
        "UIKit"
      ],
      "dependencies": {
        "ERTCSDK": [

        ],
        "VCSSDK": [

        ],
        "MMKV": [

        ],
        "Protobuf": [

        ],
        "SSZipArchive": [
          ">= 2.4.3"
        ],
        "AFNetworking": [
          ">= 4.0.0"
        ],
        "DingRTC_iOS/RtcBasic": [

        ],
        "DingRTC_iOS/AudioEnhance": [

        ]
      },
      "pod_target_xcconfig": {
        "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) VCS_USE_PROTOBUF_BEAUTY_IMPORTS=1 MRTC_DINGRTC_ENABLED=1"
      },
      "user_target_xcconfig": {
        "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) VCS_USE_PROTOBUF_BEAUTY_IMPORTS=1 MRTC_DINGRTC_ENABLED=1"
      }
    }
  ]
}
