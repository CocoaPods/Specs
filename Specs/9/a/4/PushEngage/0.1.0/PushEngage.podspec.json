{
  "name": "PushEngage",
  "version": "0.1.0",
  "summary": "iOS framework to support APNs Services PushEngage.",
  "description": "PushEngage iOS SDK adds Apple Push Notification support to your app:\nsubscriber management, rich notifications (images, deep links, custom\nsounds), action buttons, and click/view analytics integrated with the\nPushEngage dashboard.",
  "homepage": "https://github.com/awesomemotive/pushengage-ios-sdk.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "PushEngage": "care@pushengage.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "requires_arc": true,
  "source": {
    "git": "https://github.com/awesomemotive/pushengage-ios-sdk.git",
    "tag": "0.1.0"
  },
  "ios": {
    "frameworks": "UIKit"
  },
  "source_files": "Sources/PushEngage/**/*.{swift}",
  "swift_versions": "5.0",
  "pod_target_xcconfig": {
    "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "$(inherited) $(PE_EXT_API_ONLY_CONDITION_$(APPLICATION_EXTENSION_API_ONLY))",
    "PE_EXT_API_ONLY_CONDITION_YES": "APPLICATION_EXTENSION_API_ONLY"
  },
  "swift_version": "5.0"
}
