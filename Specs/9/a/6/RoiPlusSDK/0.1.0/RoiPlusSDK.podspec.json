    ]
  },
  "frameworks": [
    "AVFoundation",
    "CoreLocation",
    "CoreMotion",
    "WebKit",
    "AdSupport",
    "CoreTelephony",
    "QuartzCore"
  ],
  "libraries": [
    "sqlite3"
  ],
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "CLANG_ENABLE_MODULES": "YES"
  }
