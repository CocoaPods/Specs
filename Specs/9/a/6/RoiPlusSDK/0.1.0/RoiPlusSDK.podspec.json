{
  "name": "RoiPlusSDK",
  "version": "0.1.0",
  "summary": "RoiPlusSDK iOS advertising SDK.",
  "description": "RoiPlusSDK is an Objective-C advertising SDK supporting multiple ad formats.",
  "homepage": "https://roiplus.ixiaochuan.cn",
  "license": {
    "type": "Copyright",
    "text": "Copyright © 2026 北京云出岫文化有限公司. All Rights Reserved."
  },
  "authors": {
    "xujiangtao": "xujiangtao2014@xiaochuankeji.cn",
    "liujiayin": "liujiayin2014@xiaochuankeji.cn"
  },
  "source": {
    "http": "https://roiplus.ixiaochuan.cn/RoiPlusSDK/iOS/0.1.0/RoiPlusSDK.xcframework.zip",
    "sha256": "de3c22e60bbfe9977b442bac86c344ba6b8f2a5087ccde3151adfa4d00b235bb"
  },
  "platforms": {
    "ios": "13.0"
  },
  "requires_arc": true,
  "module_name": "RoiPlusSDK",
  "vendored_frameworks": "RoiPlusSDK.xcframework",
  "user_target_xcconfig": {
    "OTHER_LDFLAGS": "-ObjC"
  },
  "resource_bundles": {
