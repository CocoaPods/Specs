{
  "name": "SellwildSDK",
  "version": "1.4.0",
  "summary": "Sellwild mobile advertising SDK for iOS",
  "description": "SellwildSDK provides native iOS components for embedding\nSellwild marketplace listings and ad units in mobile apps.\nBanner ads run a native Prebid Mobile auction and render\nin a GAMBannerView — no WebView in the ad path.",
  "homepage": "https://github.com/Antengo/sellwild-sdk",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Sellwild": "sdk@sellwild.com"
  },
  "source": {
    "git": "https://github.com/Antengo/sellwild-sdk.git",
    "tag": "1.4.0"
  },
  "platforms": {
    "ios": "13.0"
  },
  "swift_versions": "5.5",
  "static_framework": true,
  "source_files": "ios/Sources/SellwildSDK/**/*.swift",
  "frameworks": [
    "UIKit",
    "WebKit",
    "Foundation"
  ],
  "dependencies": {
    "PrebidMobile": [
      ">= 3.0.1",
      "< 4.0"
    ],
    "Google-Mobile-Ads-SDK": [
      ">= 12.0",
      "< 14.0"
    ]
  },
  "swift_version": "5.5"
}
