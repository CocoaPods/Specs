{
  "name": "GGQQSDKManager",
  "version": "0.1.0",
  "summary": "A reusable pod library for QQ SDK",
  "description": "封装QQSDK，提供登录、分享等功能的便捷接口。",
  "homepage": "https://github.com/github6022244/GGQQSDKManager.git",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "github6022244": "1563084860@qq.com"
  },
  "source": {
    "git": "https://github.com/github6022244/GGQQSDKManager.git",
    "tag": "0.1.0"
  },
  "platforms": {
    "ios": "13.0"
  },
  "source_files": "GGQQSDKManager/Classes/*.{h,m}",
  "public_header_files": "GGQQSDKManager/Classes/*.h",
  "resources": [
    "GGQQSDKManager/Assets/**/*.png",
    "GGQQSDKManager/Assets/**/*.bundle"
  ],
  "vendored_frameworks": "GGQQSDKManager/Classes/TencentOpenAPI.framework",
  "frameworks": [
    "Security",
    "SystemConfiguration",
    "CoreGraphics",
    "CoreTelephony",
    "Foundation",
    "UIKit",
    "WebKit"
  ],
  "libraries": [
    "iconv",
    "sqlite3",
    "z",
    "c++"
  ],
  "xcconfig": {
    "OTHER_LDFLAGS": "-ObjC -all_load"
  },
  "pod_target_xcconfig": {
    "ENABLE_BITCODE": "NO",
    "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
  },
  "requires_arc": true,
  "swift_versions": [
    "5.0"
  ],
  "swift_version": "5.0"
}
