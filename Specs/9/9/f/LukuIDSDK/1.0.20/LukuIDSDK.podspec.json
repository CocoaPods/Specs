{
  "name": "LukuIDSDK",
  "version": "1.0.20",
  "summary": "LukuID iOS SDK for device communication and .luku verification.",
  "description": "LukuID iOS SDK for connecting to LukuID devices, parsing and verifying .luku\nforensic evidence archives, and sharing the same verification model as the\nother platform SDKs.",
  "homepage": "https://github.com/lukuid/sdk",
  "license": {
    "type": "Apache-2.0",
    "file": "LICENSE"
  },
  "authors": {
    "LukuID": "hello@lukuid.com"
  },
  "source": {
    "git": "https://github.com/lukuid/sdk.git",
    "tag": "v1.0.20"
  },
  "swift_versions": [
    "5.9"
  ],
  "platforms": {
    "ios": "15.0",
    "osx": "12.0"
  },
  "source_files": [
    "src/ios/LukuIDSDK/Sources/LukuIDSDK/**/*.swift",
    "src/ios/LukuIDSDK/Sources/MLDSANative/*.c",
    "src/ios/LukuIDSDK/Sources/MLDSANative/include/*.h"
  ],
  "preserve_paths": "src/ios/LukuIDSDK/Sources/MLDSANative/src/**/*",
  "public_header_files": "src/ios/LukuIDSDK/Sources/MLDSANative/include/*.h",
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"${PODS_TARGET_SRCROOT}/src/ios/LukuIDSDK/Sources/MLDSANative\" \"${PODS_TARGET_SRCROOT}/src/ios/LukuIDSDK/Sources/MLDSANative/include\" \"${PODS_TARGET_SRCROOT}/src/ios/LukuIDSDK/Sources/MLDSANative/src\" \"${PODS_TARGET_SRCROOT}/src/ios/LukuIDSDK/Sources/MLDSANative/src/fips202\""
  },
  "requires_arc": true,
  "dependencies": {
    "ZIPFoundation": [
      "~> 0.9"
    ],
    "SwiftProtobuf": [
      ">= 1.25.0",
      "< 2.0"
    ]
  },
  "swift_version": "5.9"
}
