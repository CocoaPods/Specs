{
  "name": "DxpUserManagement",
  "module_name": "DxpUserManagement",
  "version": "1.0.3",
  "summary": "Dxp User Management",
  "description": "Dxp User Management SDK: User management, including login, logout, and device token reporting. Supports Swift projects via module import without a bridging header.",
  "homepage": "https://github.com/HelloGitHub123/DxpUserManagement",
  "license": "MIT",
  "authors": {
    "李标": "li.biao3@iwhalecloud.com"
  },
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/HelloGitHub123/DxpUserManagement.git",
    "tag": "1.0.3"
  },
  "source_files": "DxpUserManagement/**/*.{h,m,swift}",
  "public_header_files": [
    "DxpUserManagement/DxpUserManagement.h",
    "DxpUserManagement/Model/DxpBaseObject.h",
    "DxpUserManagement/Model/DxpDeviceReportModel.h",
    "DxpUserManagement/Model/DxpUserData.h",
    "DxpUserManagement/Model/DxpUserIdentityLogoutModel.h",
    "DxpUserManagement/Utils/DxpUserDefaults.h",
    "DxpUserManagement/Swift/DxpUserManagementSwiftBridge.h"
  ],
  "private_header_files": [
    "DxpUserManagement/Model/HJRequestProtocolForVM.h"
  ],
  "requires_arc": true,
  "static_framework": true,
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "CLANG_ENABLE_MODULES": "YES",
    "BUILD_LIBRARY_FOR_DISTRIBUTION": "YES",
    "SWIFT_VERSION": "5.0",
    "SWIFT_INSTALL_OBJC_HEADER": "YES"
  },
  "user_target_xcconfig": {
    "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES"
  },
  "dependencies": {
    "DXPNetWorkingManagerLib": [

    ],
    "DXPToolsLib": [

    ]
  },
  "swift_version": "5.0"
}
