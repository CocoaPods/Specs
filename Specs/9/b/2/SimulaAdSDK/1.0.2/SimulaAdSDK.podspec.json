{
  "name": "SimulaAdSDK",
  "version": "1.0.2",
  "summary": "Interactive, AI-native ad experiences for modern apps",
  "description": "SimulaAdSDK enables developers to integrate interactive, opt-in AI-native ads\nincluding sponsored characters and mini-games. Designed for high engagement,\ncontextual relevance, and seamless in-app experiences.",
  "homepage": "https://github.com/Simula-AI-SDK/simula-ad-sdk-swift",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "Simula AI": "admin@simula.ad"
  },
  "source": {
    "git": "https://github.com/Simula-AI-SDK/simula-ad-sdk-swift.git",
    "tag": "1.0.2"
  },
  "platforms": {
    "ios": "15.0"
  },
  "swift_versions": "5.9",
  "source_files": "Sources/SimulaAdSDK/**/*.swift",
  "resource_bundles": {
    "SimulaAdSDK": [
      "Sources/SimulaAdSDK/Resources/*.png",
      "Sources/SimulaAdSDK/Resources/PrivacyInfo.xcprivacy"
    ]
  },
  "frameworks": [
    "StoreKit",
    "SafariServices",
    "WebKit",
    "SwiftUI",
    "Combine"
  ],
  "requires_arc": true,
  "module_name": "SimulaAdSDK",
  "documentation_url": "https://github.com/Simula-AI-SDK/simula-ad-sdk-swift",
  "swift_version": "5.9"
}
